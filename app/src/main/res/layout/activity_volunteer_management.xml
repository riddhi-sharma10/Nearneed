<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    tools:ignore="HardcodedText,ContentDescription">

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomActions"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- App Bar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back_arrow" />

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Volunteers"
                    android:textColor="@color/text_header"
                    android:textSize="18sp" />

                <ImageButton
                    android:id="@+id/btnOptions"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_more_dots"
                    app:tint="@color/text_header" />
            </RelativeLayout>

            <!-- Post Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Food Donation Drive"
                    android:textColor="@color/text_header"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Organized by Community Food Bank"
                    android:textColor="@color/text_subheadline"
                    android:textSize="14sp" />

                <!-- Slots Progress -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp">

                            <TextView
                                style="@style/AppHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/tvSlotsFilled"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="4 of 8 slots filled"
                        android:textColor="@color/brand_error_solid"
                        android:textSize="14sp"
                        style="@style/AppHeading" />
                </RelativeLayout>

                <!-- Normal Progress Bar -->
                <ProgressBar
                    android:id="@+id/pbSlots"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:progress="50"
                    android:max="100"
                    android:progressDrawable="@drawable/bg_progress_bar_red_flat" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="32dp"
                    android:background="@color/divider_soft" />
            </LinearLayout>

            <!-- ACCEPTED VOLUNTEERS Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="ACCEPTED VOLUNTEERS"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        style="@style/AppHeading"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_pill_pink_transparent"
                        android:text="Confirmed"
                        android:textColor="@color/brand_error_solid"
                        android:textSize="12sp"
                        style="@style/AppHeading"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />
                </RelativeLayout>

                <!-- Volunteer 1: Manju W -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_circle_grey_solid"
                        android:src="@drawable/user_manju" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Manju W"
                                    android:textColor="@color/text_header"
                                    android:textSize="16sp"
                                    style="@style/AppHeading" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="★ 4.9 • 24 missions"
                            android:textColor="@color/text_subheadline"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageButton
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_call_outline"
                        android:layout_marginEnd="12dp" />

                    <ImageButton
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_chat_outline"
                        android:layout_marginEnd="16dp" />

                    <!-- Empty Checkbox -->
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_card_outline" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/divider_soft" />

                <!-- Volunteer 2: Sarah -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_circle_grey_solid"
                        android:src="@drawable/user_sarah" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Sarah"
                                    android:textColor="@color/text_header"
                                    android:textSize="16sp"
                                    style="@style/AppHeading" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="★ 5.0 • 12 missions"
                            android:textColor="@color/text_subheadline"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageButton
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_call_outline"
                        android:layout_marginEnd="12dp" />

                    <ImageButton
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_chat_outline"
                        android:layout_marginEnd="16dp" />

                    <!-- Checked Checkbox -->
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_circle_solid_red"
                        android:backgroundTint="@color/brand_error_vibrant"
                        android:padding="4dp"
                        android:src="@drawable/ic_check_solid_white" />
                </LinearLayout>

                <!-- Volunteer 3: Parth (Initially Hidden) -->
                <View
                    android:id="@+id/divAcceptedParth"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="24dp"
                    android:background="@color/divider_soft"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/rowAcceptedParth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_circle_grey_solid"
                        android:src="@drawable/user_parth" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Parth Sharma"
                            android:textColor="@color/text_header"
                            android:textSize="16sp"
                            style="@style/AppHeading" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="★ 4.7 • 8 missions"
                            android:textColor="@color/text_subheadline"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageButton
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_call_outline"
                        android:layout_marginEnd="12dp" />

                    <ImageButton
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_chat_outline"
                        android:layout_marginEnd="16dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_card_outline" />
                </LinearLayout>

                <!-- Volunteer 4: Mehak (Initially Hidden) -->
                <View
                    android:id="@+id/divAcceptedMehak"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="24dp"
                    android:background="@color/divider_soft"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/rowAcceptedMehak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_circle_grey_solid"
                        android:src="@drawable/user_mehak" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mehak"
                            android:textColor="@color/text_header"
                            android:textSize="16sp"
                            style="@style/AppHeading" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="★ 4.8 • 15 missions"
                            android:textColor="@color/text_subheadline"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageButton
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_call_outline"
                        android:layout_marginEnd="12dp" />

                    <ImageButton
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_chat_outline"
                        android:layout_marginEnd="16dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_card_outline" />
                </LinearLayout>
            </LinearLayout>

            <!-- WAITLIST Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="WAITLIST (2 PEOPLE)"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    style="@style/AppHeading"
                    android:letterSpacing="0.05" />

                <!-- Waitlist 1: Parth Sharma -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWaitlistParth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeColor="@color/divider_soft"
                    app:strokeWidth="1dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:scaleType="centerCrop"
                            android:background="@drawable/bg_circle_grey_solid"
                            android:src="@drawable/user_parth" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Parth Sharma"
                                android:textColor="@color/text_header"
                                android:textSize="14sp"
                                style="@style/AppHeading" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Requested 2h ago"
                                android:textColor="@color/text_subheadline"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPromoteParth"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Promote"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textAllCaps="false"
                            app:backgroundTint="@color/brand_error_solid"
                            app:cornerRadius="8dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:paddingHorizontal="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Waitlist 2: Mehak -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWaitlistMehak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeColor="@color/divider_soft"
                    app:strokeWidth="1dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:scaleType="centerCrop"
                            android:background="@drawable/bg_circle_grey_solid"
                            android:src="@drawable/user_mehak" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mehak"
                                android:textColor="@color/text_header"
                                android:textSize="14sp"
                                style="@style/AppHeading" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Requested 5h ago"
                                android:textColor="@color/text_subheadline"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPromoteMehak"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Promote"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textAllCaps="false"
                            app:backgroundTint="@color/brand_error_solid"
                            app:cornerRadius="8dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:paddingHorizontal="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="32dp" />
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Actions Sticky -->
    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:background="@color/surface_background_clean"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddSlot"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Add a Slot"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:icon="@drawable/ic_add_circular"
            app:iconGravity="textStart"
            app:iconTint="@color/white"
            app:backgroundTint="@color/brand_error_solid"
            app:cornerRadius="16dp"
            android:elevation="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseApps"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Close Applications"
            android:textColor="@color/brand_error_solid"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:icon="@drawable/ic_close_circular"
            app:iconGravity="textStart"
            app:iconTint="@color/brand_error_solid"
            app:backgroundTint="@color/surface_background_clean"
            app:strokeColor="@color/brand_error_solid"
            app:strokeWidth="1dp"
            app:cornerRadius="16dp"
            android:elevation="0dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>









