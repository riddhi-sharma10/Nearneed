<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:ignore="HardcodedText">

    <RelativeLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back_arrow"
            app:tint="@color/text_header" />

        <TextView
            style="@style/AppHeading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Guidelines"
            android:textColor="@color/text_header"
            android:textSize="18sp" />

    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                style="@style/AppHero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Trust and Safety\nGuidelines"
                android:textColor="@color/text_header"
                android:textSize="24sp"
                android:letterSpacing="-0.01" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="NearNeed is built on mutual trust. To ensure a safe environment for all neighbors, please adhere to these verification guidelines."
                android:textColor="@color/text_subheadline"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp" />

            <TextView
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="1. Accuracy of Information"
                android:textColor="@color/text_header"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="You agree that all information provided during ID verification is accurate and belongs to you. Impersonation is strictly prohibited."
                android:textColor="@color/text_subheadline"
                android:textSize="14sp" />

            <TextView
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="2. Data Privacy"
                android:textColor="@color/text_header"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="We store your ID securely for verification purposes only. Your personal details will never be shared with other users without your explicit consent."
                android:textColor="@color/text_subheadline"
                android:textSize="14sp" />

            <TextView
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="3. Prohibited Content"
                android:textColor="@color/text_header"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Uploading forged, expired, or tampered documents will result in permanent account suspension."
                android:textColor="@color/text_subheadline"
                android:textSize="14sp" />

            <TextView
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="4. Community Conduct"
                android:textColor="@color/text_header"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Verified members are expected to interact respectfully and fulfill their commitments to neighbors."
                android:textColor="@color/text_subheadline"
                android:textSize="14sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="48dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
