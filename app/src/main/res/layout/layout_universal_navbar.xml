<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- White navbar bar (no card for the FAB – it floats above) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/navbarCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="0dp"
        app:cardElevation="12dp"
        app:cardPreventCornerOverlap="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/white"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <!-- Home -->
            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivNavHome"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_home"
                    app:tint="@color/text_muted"
                    android:importantForAccessibility="no" />
                <TextView
                    android:id="@+id/tvNavHome"
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_home"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <!-- Map -->
            <LinearLayout
                android:id="@+id/navMap"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivNavMap"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_map"
                    app:tint="@color/text_muted"
                    android:importantForAccessibility="no" />
                <TextView
                    android:id="@+id/tvNavMap"
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_map"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <!-- Empty centre slot (space reserved for the floating FAB) -->
            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <!-- Messages -->
            <LinearLayout
                android:id="@+id/navMessages"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivNavMessages"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_messages"
                    app:tint="@color/text_muted"
                    android:importantForAccessibility="no" />
                <TextView
                    android:id="@+id/tvNavMessages"
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_messages"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <!-- Profile -->
            <LinearLayout
                android:id="@+id/navProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivNavProfile"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_profile"
                    app:tint="@color/brand_primary"
                    android:importantForAccessibility="no" />
                <TextView
                    android:id="@+id/tvNavProfile"
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/brand_primary"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Floating circle FAB – sits above the navbar, centred -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/fabAdd"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="25dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:padding="0dp"
        app:backgroundTint="@color/brand_primary"
        app:icon="@drawable/ic_plus_white"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="28dp"
        app:iconTint="@color/white"
        app:cornerRadius="29dp"
        app:elevation="32dp"
        android:elevation="32dp"
        android:translationZ="30dp"
        android:stateListAnimator="@null"
        app:rippleColor="@color/brand_primary_dark"
        android:importantForAccessibility="no"
        android:clickable="true"
        android:focusable="true" />

</merge>
