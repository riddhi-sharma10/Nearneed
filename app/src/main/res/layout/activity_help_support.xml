<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="60dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp">
        
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back_arrow" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Help &amp; Support"
            android:textColor="#101D33"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Frequently Asked Questions"
                android:textColor="#101D33"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black" />

            <!-- FAQ Item 1 -->
            <LinearLayout
                android:id="@+id/faq_item_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_base"
                android:elevation="6dp"
                android:outlineSpotShadowColor="#E2E8F0">
                
                <RelativeLayout
                    android:id="@+id/faq_header_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/faq_arrow_1"
                        android:layout_marginEnd="12dp"
                        android:text="How do I post a gig?"
                        android:textColor="#0F172A"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                        
                    <ImageView
                        android:id="@+id/faq_arrow_1"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_dropdown_small"
                        app:tint="#CBD5E1" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/faq_answer_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:text="Tap the blue + button on the home screen and select whether it's a paid gig or a community act of help."
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- FAQ Item 2 -->
            <LinearLayout
                android:id="@+id/faq_item_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_base"
                android:elevation="6dp"
                android:outlineSpotShadowColor="#E2E8F0">
                
                <RelativeLayout
                    android:id="@+id/faq_header_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/faq_arrow_2"
                        android:layout_marginEnd="12dp"
                        android:text="How do I get ID Verified?"
                        android:textColor="#0F172A"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                        
                    <ImageView
                        android:id="@+id/faq_arrow_2"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_dropdown_small"
                        app:tint="#CBD5E1" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/faq_answer_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:text="Go to settings or your profile and follow the steps to submit an ID document to our verification provider."
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- FAQ Item 3 -->
            <LinearLayout
                android:id="@+id/faq_item_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_base"
                android:elevation="6dp"
                android:outlineSpotShadowColor="#E2E8F0">
                
                <RelativeLayout
                    android:id="@+id/faq_header_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/faq_arrow_3"
                        android:layout_marginEnd="12dp"
                        android:text="Is there a fee for NearNeed?"
                        android:textColor="#0F172A"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                        
                    <ImageView
                        android:id="@+id/faq_arrow_3"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_dropdown_small"
                        app:tint="#CBD5E1" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/faq_answer_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:text="NearNeed is free to use for community help acts. For paid gigs, we take a small 5% service fee from the gig provider to maintain the platform."
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- FAQ Item 4 -->
            <LinearLayout
                android:id="@+id/faq_item_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_base"
                android:elevation="6dp"
                android:outlineSpotShadowColor="#E2E8F0">
                
                <RelativeLayout
                    android:id="@+id/faq_header_4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/faq_arrow_4"
                        android:layout_marginEnd="12dp"
                        android:text="How do I change my location?"
                        android:textColor="#0F172A"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                        
                    <ImageView
                        android:id="@+id/faq_arrow_4"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_dropdown_small"
                        app:tint="#CBD5E1" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/faq_answer_4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:text="Your location is detected automatically, but you can update your preferred neighborhood in the Settings > Privacy section."
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- FAQ Item 5 -->
            <LinearLayout
                android:id="@+id/faq_item_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_base"
                android:elevation="6dp"
                android:outlineSpotShadowColor="#E2E8F0">
                
                <RelativeLayout
                    android:id="@+id/faq_header_5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/faq_arrow_5"
                        android:layout_marginEnd="12dp"
                        android:text="What is a 'Neighbour Score'?"
                        android:textColor="#0F172A"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                        
                    <ImageView
                        android:id="@+id/faq_arrow_5"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_dropdown_small"
                        app:tint="#CBD5E1" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/faq_answer_5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:text="Your score is based on reviews from other users and your frequency of helping others without charge. A high score earns you trust and badges."
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- FAQ Item 6 -->
            <LinearLayout
                android:id="@+id/faq_item_6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_base"
                android:elevation="6dp"
                android:outlineSpotShadowColor="#E2E8F0">
                
                <RelativeLayout
                    android:id="@+id/faq_header_6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/faq_arrow_6"
                        android:layout_marginEnd="12dp"
                        android:text="How do I report a user?"
                        android:textColor="#0F172A"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                        
                    <ImageView
                        android:id="@+id/faq_arrow_6"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_dropdown_small"
                        app:tint="#CBD5E1" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/faq_answer_6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:text="On any profile or post, tap the three dots in the top right and select 'Report'. Our team will review the case within 24 hours."
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="32dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContactUs"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:text="Contact Us"
                android:textColor="#1D5EF3"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                app:backgroundTint="#E0F2FE"
                app:cornerRadius="12dp"
                android:elevation="0dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
