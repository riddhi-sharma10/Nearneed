<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlaySheet"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/overlay_dark_light"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:id="@+id/bottomSheetContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_sheet_top_rounded"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="32dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:clickable="true"
        android:focusable="true">

        <!-- Drag Handle -->
        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_pill_grey"
            android:layout_marginBottom="24dp" />

        <!-- Title & Subtitle -->
        <TextView
            style="@style/AppHeading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Offer to Help"
            android:textColor="@color/text_header"
            android:textSize="20sp" />

        <TextView
            style="@style/AppDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Emergency food delivery for senior"
            android:textColor="@color/text_subheadline"
            android:textSize="14sp" />

        <!-- Spot Availability Card -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card_spot_pink"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_centerVertical="true">
                
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Spot Availability"
                    android:textColor="@color/text_header"
                    android:textSize="14sp" />

                <TextView
                    style="@style/AppDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="You are applying for Spot 3 of 4."
                    android:textColor="@color/text_subheadline"
                    android:textSize="14sp" />
            </LinearLayout>

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:padding="8dp"
                android:background="@drawable/bg_circle_solid_white"
                android:src="@drawable/ic_check_solid_white" 
                app:tint="@color/brand_error_solid" />
        </RelativeLayout>

        <!-- Introduction -->
                            <TextView
                                style="@style/AppHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />

        <EditText
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:gravity="top|start"
            android:hint="Introduce yourself and explain why you're a good fit..."
            android:textColorHint="@color/text_muted"
            android:padding="16dp"
            android:textSize="14sp" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                style="@style/AppHeading"
                android:background="@drawable/bg_card_outline"
                android:gravity="center"
                android:text="Call"
                android:textColor="@color/text_header"
                android:textSize="14sp"
                app:drawableStartCompat="@drawable/ic_phone_outline"
                app:drawableTint="@color/text_subheadline"
                android:drawablePadding="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                style="@style/AppHeading"
                android:background="@drawable/bg_card_outline"
                android:gravity="center"
                android:text="SMS"
                android:textColor="@color/text_header"
                android:textSize="14sp"
                app:drawableStartCompat="@drawable/ic_solid_sms"
                app:drawableTint="@color/text_subheadline"
                android:drawablePadding="8dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendResponse"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="Send Response"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:icon="@drawable/ic_forward_arrow"
            app:iconGravity="textEnd"
            app:iconTint="@color/white"
            app:backgroundTint="@color/brand_error_solid"
            app:cornerRadius="16dp"
            android:elevation="0dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            style="@style/AppDescription"
            android:text="By responding, you agree to our Community Guidelines and acknowledge that your profile details will be shared with the organizer."
            android:textColor="@color/text_muted"
            android:textSize="11sp" />
    </LinearLayout>
</FrameLayout>









