<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:layout_centerVertical="true" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_back_arrow" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" android:text="Profile Setup" android:textColor="#101D33" android:textSize="16sp" android:textStyle="bold" />
            </RelativeLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:orientation="horizontal" android:weightSum="1" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Step 3/4" android:textColor="#101D33" android:textSize="14sp" android:fontFamily="sans-serif-medium" />
            </LinearLayout>
            <ProgressBar style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="8dp" android:progress="75" android:max="100" android:progressDrawable="@drawable/bg_progress_bar_blue_flat" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:text="What kind of help do you usually need?" android:textColor="#101D33" android:textSize="24sp" android:fontFamily="sans-serif-black" android:letterSpacing="-0.02" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cgNeeds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="House Help"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue" android:checked="true"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Plumbing"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Electrical"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Cleaning"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue" android:checked="true"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Cooking"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Gardening"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Pet Sitting"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Photography"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Tutor"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Elderly Care"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Babysitting"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Tech Support"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
            </com.google.android.material.chip.ChipGroup>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="40dp" android:text="What tasks can you offer?" android:textColor="#101D33" android:textSize="24sp" android:fontFamily="sans-serif-black" android:letterSpacing="-0.02" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cgOffers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="House Help"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue" />
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Plumbing"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue" android:checked="true"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Electrical"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Cleaning"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue" />
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Cooking"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue" android:checked="true"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Tech Support"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue" android:checked="true"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Car Wash"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Personal Training"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Event Help"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Tutor"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="48dp" android:text="Delivery"
                    style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
            </com.google.android.material.chip.ChipGroup>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="40dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnter"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Enter"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                app:backgroundTint="#1D5EF3"
                app:cornerRadius="16dp"
                android:elevation="0dp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>