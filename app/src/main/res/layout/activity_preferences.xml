<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:layout_centerVertical="true" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_back_arrow" />
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Profile Setup"
                    android:textColor="@color/text_header"
                    android:textSize="16sp" />
            </RelativeLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Preferences"
                    android:textColor="@color/text_header"
                    android:textSize="14sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Step 3/4" android:textColor="@color/text_muted" android:textSize="12sp" />
            </LinearLayout>
            <ProgressBar style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="8dp" android:progress="75" android:max="100" android:progressDrawable="@drawable/bg_progress_bar_blue_flat" />

            <TextView
                style="@style/AppHero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="What kind of help do you usually need?"
                android:textColor="@color/text_header"
                android:textSize="24sp"
                android:letterSpacing="-0.02" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cgNeeds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="House Help"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Plumbing"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Electrical"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cleaning"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cooking"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gardening"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pet Sitting"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Photography"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tutor"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Elderly Care"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Babysitting"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipOtherNeed"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+ Other"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
            </com.google.android.material.chip.ChipGroup>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilOtherNeed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/brand_primary"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:hintEnabled="false"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etOtherNeed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="What else do you need?"
                    android:inputType="text"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                style="@style/AppHero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="What tasks can you offer?"
                android:textColor="@color/text_header"
                android:textSize="24sp"
                android:letterSpacing="-0.02" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cgOffers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.chip.Chip
                    android:id="@+id/pref_offer_househelp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="House Help"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/pref_offer_plumbing"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Plumbing"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/pref_offer_electrical"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Electrical"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/pref_offer_cleaning"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cleaning"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/pref_offer_cooking"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cooking"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/pref_offer_techsupport"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tech Support"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/pref_offer_carwash"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Car Wash"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/pref_offer_personaltraining"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Personal Training"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/pref_offer_eventhelp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Event Help"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/pref_offer_tutor"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tutor"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipOtherOffer"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+ Other"
                    style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
            </com.google.android.material.chip.ChipGroup>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilOtherOffer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/brand_primary"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:hintEnabled="false"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etOtherOffer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="What else can you offer?"
                    android:inputType="text"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnter"
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="24dp"
                android:elevation="0dp"
                android:text="Enter"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="16dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="40dp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>








