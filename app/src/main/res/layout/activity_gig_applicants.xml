<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════ TOP APP BAR ══════════ -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:background="#FFFFFF">

                <!-- Back Button -->
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back_arrow"
                    android:padding="8dp" />

                <!-- Title + Subtitle -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Responses"
                        android:textColor="#101D33"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plumbing Repair"
                        android:textColor="#94A3B8"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Three-dot menu -->
                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:gravity="center"
                    android:text="⋮"
                    android:textColor="#101D33"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- ══════════ HERO IMAGE ══════════ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp">

                <!-- Background image -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/bg_image_placeholder"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_circle_light_green" />

                <!-- Dark gradient overlay -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_gradient_overlay" />

                <!-- Gig title overlay -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="16dp"
                    android:text="Plumbing Repair"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- ══════════ STATS BAR ══════════ -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="3 people responded"
                    android:textColor="#475569"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="0 of 1 spots filled"
                    android:textColor="#94A3B8"
                    android:textSize="12sp" />
            </RelativeLayout>

            <!-- Thin progress track -->
            <ProgressBar
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:max="1"
                android:progress="0"
                android:progressTint="#1D5EF3"
                android:progressBackgroundTint="#E2E8F0" />

            <!-- ══════════ APPLICANT CARDS ══════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <!-- ─── CARD 1: Rahul S. (expanded / top applicant) ─── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardRahul"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Avatar + Name + Rating row -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <!-- Avatar frame with verified badge -->
                            <FrameLayout
                                android:id="@+id/avRahulFrame"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:layout_centerVertical="true">

                                <ImageView
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:background="@drawable/bg_circle_light_blue"
                                    android:src="@drawable/bg_image_placeholder"
                                    android:scaleType="centerCrop" />

                                <!-- Verified badge -->
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="bottom|end"
                                    android:src="@drawable/ic_verified_blue" />
                            </FrameLayout>

                            <!-- Name + message preview -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/avRahulFrame"
                                android:layout_toStartOf="@+id/tvRatingRahul"
                                android:layout_marginStart="12dp"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Rahul S."
                                    android:textColor="#0F172A"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Hi, I live in the same block and have my own tools..."
                                    android:textColor="#64748B"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp"
                                    android:maxLines="2"
                                    android:ellipsize="end" />
                            </LinearLayout>

                            <!-- Star rating -->
                            <LinearLayout
                                android:id="@+id/tvRatingRahul"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/ic_star_yellow" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="3dp"
                                    android:text="4.8"
                                    android:textColor="#D97706"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </RelativeLayout>

                        <!-- Proposed price chip -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:layout_marginTop="14dp"
                            android:background="@drawable/bg_alert_yellow"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_cash_icon"
                                app:tint="#D97706" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Proposed ₹250 "
                                android:textColor="#92400E"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="(you posted ₹300)"
                                android:textColor="#D97706"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <!-- Action buttons row 1: Accept + Counter -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="12dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnAcceptRahul"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="44dp"
                                android:layout_marginEnd="8dp"
                                android:text="Accept ₹250"
                                android:textColor="#FFFFFF"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                app:backgroundTint="#16A34A"
                                app:cornerRadius="10dp"
                                android:elevation="0dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnCounterRahul"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="44dp"
                                android:text="Counter"
                                android:textColor="#FFFFFF"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                app:backgroundTint="#1D5EF3"
                                app:cornerRadius="10dp"
                                android:elevation="0dp" />
                        </LinearLayout>

                        <!-- Action buttons row 2: Decline + Chat -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnDeclineRahul"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_alignParentStart="true"
                                android:layout_toStartOf="@+id/btnChatRahul"
                                android:layout_marginEnd="8dp"
                                android:text="Decline"
                                android:textColor="#475569"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                app:backgroundTint="#F1F5F9"
                                app:cornerRadius="10dp"
                                android:elevation="0dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnChatRahul"
                                android:layout_width="50dp"
                                android:layout_height="44dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                app:icon="@drawable/ic_chat_outline"
                                app:iconGravity="textStart"
                                app:iconTint="#1D5EF3"
                                app:backgroundTint="#EFF6FF"
                                app:strokeColor="#BFDBFE"
                                app:strokeWidth="1dp"
                                app:cornerRadius="10dp"
                                android:elevation="0dp"
                                android:paddingStart="0dp"
                                android:paddingEnd="0dp" />
                        </RelativeLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ─── CARD 2: Priya M. (collapsed preview) ─── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPriya"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <!-- Avatar -->
                        <ImageView
                            android:id="@+id/avPriya"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_circle_grey_icon"
                            android:src="@drawable/bg_image_placeholder"
                            android:scaleType="centerCrop" />

                        <!-- Name + preview -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/avPriya"
                            android:layout_toStartOf="@+id/tvRatingPriya"
                            android:layout_marginStart="12dp"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Priya M."
                                android:textColor="#0F172A"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Available this weekend, I have experience with taps..."
                                android:textColor="#94A3B8"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"
                                android:maxLines="1"
                                android:ellipsize="end" />
                        </LinearLayout>

                        <!-- Rating -->
                        <LinearLayout
                            android:id="@+id/tvRatingPriya"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_star_yellow" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="3dp"
                                android:text="4.5"
                                android:textColor="#D97706"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- ─── CARD 3: Anika R. (collapsed preview) ─── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAnika"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <!-- Avatar -->
                        <ImageView
                            android:id="@+id/avAnika"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_circle_peach"
                            android:src="@drawable/bg_image_placeholder"
                            android:scaleType="centerCrop" />

                        <!-- Name + preview -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/avAnika"
                            android:layout_toStartOf="@+id/tvRatingAnika"
                            android:layout_marginStart="12dp"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Anika R."
                                android:textColor="#0F172A"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="I'm a certified plumber, can come within the hour."
                                android:textColor="#94A3B8"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"
                                android:maxLines="1"
                                android:ellipsize="end" />
                        </LinearLayout>

                        <!-- Rating -->
                        <LinearLayout
                            android:id="@+id/tvRatingAnika"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_star_yellow" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="3dp"
                                android:text="4.9"
                                android:textColor="#D97706"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom App Navigation System -->
    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bottomAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:fabAlignmentMode="center"
        app:fabCradleMargin="8dp"
        app:fabCradleRoundedCornerRadius="16dp"
        app:hideOnScroll="false"
        app:backgroundTint="#EBFFFFFF">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            style="@style/Widget.MaterialComponents.BottomNavigationView"
            android:id="@+id/bottomNavView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:menu="@menu/bottom_nav_menu"
            app:itemIconTint="@color/sel_bottom_nav_color"
            app:itemTextColor="@color/sel_bottom_nav_color"
            app:itemRippleColor="#E0F2FE"
            app:labelVisibilityMode="labeled" />
    </com.google.android.material.bottomappbar.BottomAppBar>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:importantForAccessibility="no"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:backgroundTint="#2563EB"
        app:tint="#FFFFFF"
        app:srcCompat="@drawable/ic_plus_white"
        app:cornerRadius="28dp"
        app:layout_anchor="@id/bottomAppBar"
        android:layout_marginBottom="16dp"
        android:outlineAmbientShadowColor="#2563EB"
        android:outlineSpotShadowColor="#2563EB"
        android:elevation="8dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
