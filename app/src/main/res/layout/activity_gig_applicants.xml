<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background">

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════ TOP APP BAR ══════════ -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:elevation="4dp"
                android:background="@color/white">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/plumbing_repair_hero"
                    android:scaleType="centerCrop"
                    android:alpha="0.1" />

                <!-- Back Button -->
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back_arrow"
                    android:padding="8dp" />

                <!-- Title + Subtitle -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Responses"
                        android:textColor="@color/text_header"
                        android:textSize="17sp" />

                    <TextView
                        style="@style/AppDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plumbing Repair"
                        android:textColor="@color/text_header"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Three-dot menu -->
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:gravity="center"
                    android:text="⋮"
                    android:textColor="@color/text_header"
                    android:textSize="22sp" />
            </RelativeLayout>

            <!-- ══════════ HERO IMAGE ══════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/white">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Background image -->
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/plumbing_repair_hero"
                        android:scaleType="centerCrop" />

                    <!-- Shaded Box + Gig title overlay -->
                    <TextView
                        style="@style/AppHeading"
                        android:id="@+id/tvGigTitleOverlay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_marginBottom="24dp"
                        android:background="@drawable/bg_glass_title_box"
                        android:paddingStart="16dp"
                        android:paddingEnd="28dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:text="Plumbing Repair"
                        android:textColor="@color/text_header"
                        android:textSize="18sp"
                        android:elevation="0dp" />
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══════════ STATS BAR ══════════ -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="4dp">

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="3 people responded"
                    android:textColor="@color/text_subheadline"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvSpotsFilled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="0 of 1 spots filled"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />
            </RelativeLayout>

            <!-- Thin progress track -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:max="1"
                android:progress="0"
                android:progressTint="@color/brand_primary"
                android:progressBackgroundTint="@color/border_standard" />

            <!-- ══════════ APPLICANT CARDS ══════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <!-- ─── CARD 1: Rahul S. (expanded / top applicant) ─── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardRahul"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Avatar + Name + Rating row -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <!-- Avatar frame without badge -->
                            <FrameLayout
                                android:id="@+id/avRahulFrame"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:layout_centerVertical="true">

                                <ImageView
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:background="@drawable/bg_circle_light_blue"
                                    android:src="@drawable/bg_image_placeholder"
                                    android:scaleType="centerCrop" />
                            </FrameLayout>

                            <!-- Name + message preview -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/avRahulFrame"
                                android:layout_toStartOf="@+id/tvRatingRahul"
                                android:layout_marginStart="12dp"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        style="@style/AppHeading"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Rahul S."
                                        android:textColor="@color/text_header"
                                        android:textSize="15sp" />

                                    <!-- Verified badge next to name -->
                                    <ImageView
                                        android:layout_width="14dp"
                                        android:layout_height="14dp"
                                        android:layout_marginStart="4dp"
                                        android:src="@drawable/ic_verified_badge" />
                                </LinearLayout>

                                <TextView
                                    style="@style/AppDescription"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Hi, I live in the same block and have my own tools..."
                                    android:textColor="@color/text_subheadline"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp"
                                    android:maxLines="2"
                                    android:ellipsize="end" />
                            </LinearLayout>

                            <!-- Star rating -->
                            <LinearLayout
                                android:id="@+id/tvRatingRahul"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/ic_star_yellow" />

                                <TextView
                                    style="@style/AppHeading"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="3dp"
                                    android:text="4.8"
                                    android:textColor="@color/brand_warning_solid"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </RelativeLayout>

                        <!-- Expandable Details -->
                        <LinearLayout
                            android:id="@+id/llRahulDetails"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <!-- Proposed price chip -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="38dp"
                                android:layout_marginTop="14dp"
                                android:background="@drawable/bg_alert_yellow"
                                android:gravity="center_vertical"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_cash_icon"
                                    app:tint="@color/brand_warning_solid" />

                                <TextView
                                    style="@style/AppHeading"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Proposed ₹250 "
                                    android:textColor="@color/brand_warning_text"
                                    android:textSize="13sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="(you posted ₹300)"
                                    android:textColor="@color/brand_warning_solid"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <!-- Action buttons row 1: Accept + Counter -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="12dp">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnAcceptRahul"
                                    style="@style/AppHeading"
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="44dp"
                                    android:layout_marginEnd="8dp"
                                    android:text="Accept ₹250"
                                    android:textColor="@color/white"
                                    android:textAllCaps="false"
                                    android:textSize="13sp"
                                    app:backgroundTint="@color/brand_success_alt"
                                    app:cornerRadius="10dp"
                                    android:elevation="0dp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnCounterRahul"
                                    style="@style/AppHeading"
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="44dp"
                                    android:text="Counter"
                                    android:textColor="@color/white"
                                    android:textAllCaps="false"
                                    android:textSize="13sp"
                                    app:backgroundTint="@color/brand_primary"
                                    app:cornerRadius="10dp"
                                    android:elevation="0dp" />
                            </LinearLayout>

                            <!-- Action buttons row 2: Decline + Chat -->
                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnDeclineRahul"
                                    style="@style/AppHeading"
                                    android:layout_width="0dp"
                                    android:layout_height="44dp"
                                    android:layout_alignParentStart="true"
                                    android:layout_toStartOf="@+id/btnChatRahul"
                                    android:layout_marginEnd="8dp"
                                    android:text="Decline"
                                    android:textColor="@color/text_subheadline"
                                    android:textAllCaps="false"
                                    android:textSize="13sp"
                                    app:backgroundTint="@color/divider_soft"
                                    app:cornerRadius="10dp"
                                    android:elevation="0dp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnChatRahul"
                                    android:layout_width="50dp"
                                    android:layout_height="44dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_centerVertical="true"
                                    app:icon="@drawable/ic_chat_outline"
                                    app:iconGravity="textStart"
                                    app:iconTint="@color/brand_primary"
                                    app:backgroundTint="@color/brand_primary_light"
                                    app:strokeColor="@color/brand_info_accent_soft"
                                    app:strokeWidth="1dp"
                                    app:cornerRadius="10dp"
                                    android:elevation="0dp"
                                    android:paddingStart="0dp"
                                    android:paddingEnd="0dp" />
                            </RelativeLayout>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ─── CARD 2: Priya M. (expanded) ─── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPriya"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Avatar + Name + Rating -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <!-- Avatar frame without badge -->
                            <FrameLayout
                                android:id="@+id/avPriyaFrame"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:layout_centerVertical="true">

                                <ImageView
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:background="@drawable/bg_circle_grey_icon"
                                    android:src="@drawable/bg_image_placeholder"
                                    android:scaleType="centerCrop" />
                            </FrameLayout>

                            <!-- Name + full message -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/avPriyaFrame"
                                android:layout_toStartOf="@+id/tvRatingPriya"
                                android:layout_marginStart="12dp"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/AppHeading"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Priya M."
                                    android:textColor="@color/text_header"
                                    android:textSize="15sp" />

                                <TextView
                                    style="@style/AppDescription"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="I'm available this weekend and have 5 years of experience with tap installations and repairs."
                                    android:textColor="@color/text_subheadline"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp"
                                    android:maxLines="3"
                                    android:ellipsize="end" />
                            </LinearLayout>

                            <!-- Star rating -->
                            <LinearLayout
                                android:id="@+id/tvRatingPriya"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/ic_star_yellow" />

                                <TextView
                                    style="@style/AppHeading"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="3dp"
                                    android:text="4.5"
                                    android:textColor="@color/brand_warning_solid"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </RelativeLayout>

                        <!-- Expandable Details -->
                        <LinearLayout
                            android:id="@+id/llPriyaDetails"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <!-- Proposed price chip -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="38dp"
                                android:layout_marginTop="14dp"
                                android:background="@drawable/bg_alert_yellow"
                                android:gravity="center_vertical"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_cash_icon"
                                    app:tint="@color/brand_warning_solid" />

                                <TextView
                                    style="@style/AppHeading"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Proposed ₹250 (you posted ₹300)"
                                    android:textColor="@color/brand_warning_text"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <!-- Action buttons row 1: Accept + Counter -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:orientation="horizontal">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnAcceptPriya"
                                    style="@style/AppHeading"
                                    android:layout_width="0dp"
                                    android:layout_height="44dp"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="8dp"
                                    android:text="Accept ₹250"
                                    android:textColor="@color/white"
                                    android:textAllCaps="false"
                                    android:textSize="13sp"
                                    app:backgroundTint="@color/brand_success_alt"
                                    app:cornerRadius="10dp"
                                    android:elevation="0dp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnCounterPriya"
                                    style="@style/AppHeading"
                                    android:layout_width="0dp"
                                    android:layout_height="44dp"
                                    android:layout_weight="1"
                                    android:text="Counter"
                                    android:textColor="@color/white"
                                    android:textAllCaps="false"
                                    android:textSize="13sp"
                                    app:backgroundTint="@color/brand_primary"
                                    app:cornerRadius="10dp"
                                    android:elevation="0dp" />
                            </LinearLayout>

                            <!-- Action buttons row 2: Decline + Chat -->
                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnDeclinePriya"
                                    style="@style/AppHeading"
                                    android:layout_width="0dp"
                                    android:layout_height="44dp"
                                    android:layout_alignParentStart="true"
                                    android:layout_toStartOf="@+id/btnChatPriya"
                                    android:layout_marginEnd="8dp"
                                    android:text="Decline"
                                    android:textColor="@color/text_subheadline"
                                    android:textAllCaps="false"
                                    android:textSize="13sp"
                                    app:backgroundTint="@color/divider_soft"
                                    app:cornerRadius="10dp"
                                    android:elevation="0dp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnChatPriya"
                                    android:layout_width="50dp"
                                    android:layout_height="44dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_centerVertical="true"
                                    app:icon="@drawable/ic_chat_outline"
                                    app:iconGravity="textStart"
                                    app:iconTint="@color/brand_primary"
                                    app:backgroundTint="@color/brand_primary_light"
                                    app:strokeColor="@color/brand_info_accent_soft"
                                    app:strokeWidth="1dp"
                                    app:cornerRadius="10dp"
                                    android:elevation="0dp"
                                    android:paddingStart="0dp"
                                    android:paddingEnd="0dp" />
                            </RelativeLayout>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ─── CARD 3: Anika R. (expanded) ─── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAnika"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Avatar + Name + Rating -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <!-- Avatar frame without badge -->
                            <FrameLayout
                                android:id="@+id/avAnikaFrame"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:layout_centerVertical="true">

                                <ImageView
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:background="@drawable/bg_circle_peach"
                                    android:src="@drawable/bg_image_placeholder"
                                    android:scaleType="centerCrop" />
                            </FrameLayout>

                            <!-- Name + full message -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/avAnikaFrame"
                                android:layout_toStartOf="@+id/tvRatingAnika"
                                android:layout_marginStart="12dp"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/AppHeading"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Anika R."
                                    android:textColor="@color/text_header"
                                    android:textSize="15sp" />

                                <TextView
                                    style="@style/AppDescription"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="I'm a certified plumber, can come within the hour for any tap or plumbing repairs."
                                    android:textColor="@color/text_subheadline"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp"
                                    android:maxLines="3"
                                    android:ellipsize="end" />
                            </LinearLayout>

                            <!-- Star rating -->
                            <LinearLayout
                                android:id="@+id/tvRatingAnika"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/ic_star_yellow" />

                                <TextView
                                    style="@style/AppHeading"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="3dp"
                                    android:text="4.9"
                                    android:textColor="@color/brand_warning_solid"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </RelativeLayout>

                        <!-- Expandable Details -->
                        <LinearLayout
                            android:id="@+id/llAnikaDetails"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <!-- Proposed price chip -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="38dp"
                                android:layout_marginTop="14dp"
                                android:background="@drawable/bg_alert_yellow"
                                android:gravity="center_vertical"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_cash_icon"
                                    app:tint="@color/brand_warning_solid" />

                                <TextView
                                    style="@style/AppHeading"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Proposed ₹250 (you posted ₹300)"
                                    android:textColor="@color/brand_warning_text"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <!-- Action buttons row 1: Accept + Counter -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:orientation="horizontal">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnAcceptAnika"
                                    style="@style/AppHeading"
                                    android:layout_width="0dp"
                                    android:layout_height="44dp"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="8dp"
                                    android:text="Accept ₹250"
                                    android:textColor="@color/white"
                                    android:textAllCaps="false"
                                    android:textSize="13sp"
                                    app:backgroundTint="@color/brand_success_alt"
                                    app:cornerRadius="10dp"
                                    android:elevation="0dp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnCounterAnika"
                                    style="@style/AppHeading"
                                    android:layout_width="0dp"
                                    android:layout_height="44dp"
                                    android:layout_weight="1"
                                    android:text="Counter"
                                    android:textColor="@color/white"
                                    android:textAllCaps="false"
                                    android:textSize="13sp"
                                    app:backgroundTint="@color/brand_primary"
                                    app:cornerRadius="10dp"
                                    android:elevation="0dp" />
                            </LinearLayout>

                            <!-- Action buttons row 2: Decline + Chat -->
                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnDeclineAnika"
                                    style="@style/AppHeading"
                                    android:layout_width="0dp"
                                    android:layout_height="44dp"
                                    android:layout_alignParentStart="true"
                                    android:layout_toStartOf="@+id/btnChatAnika"
                                    android:layout_marginEnd="8dp"
                                    android:text="Decline"
                                    android:textColor="@color/text_subheadline"
                                    android:textAllCaps="false"
                                    android:textSize="13sp"
                                    app:backgroundTint="@color/divider_soft"
                                    app:cornerRadius="10dp"
                                    android:elevation="0dp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnChatAnika"
                                    android:layout_width="50dp"
                                    android:layout_height="44dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_centerVertical="true"
                                    app:icon="@drawable/ic_chat_outline"
                                    app:iconGravity="textStart"
                                    app:iconTint="@color/brand_primary"
                                    app:backgroundTint="@color/brand_primary_light"
                                    app:strokeColor="@color/brand_info_accent_soft"
                                    app:strokeWidth="1dp"
                                    app:cornerRadius="10dp"
                                    android:elevation="0dp"
                                    android:paddingStart="0dp"
                                    android:paddingEnd="0dp" />
                            </RelativeLayout>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Universal Navigation System -->
    <include layout="@layout/layout_universal_navbar" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>









