<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_background">

    <!-- Top Header Spacer -->
    <View android:layout_width="match_parent" android:layout_height="60dp" android:background="@color/white" />

    <!-- Top Header -->
    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/white"
        android:elevation="2dp">
        <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:layout_centerVertical="true" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_back_arrow" />
        <TextView
            style="@style/AppHeading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Saved Tasks"
            android:textColor="@color/text_header"
            android:textSize="18sp" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">

            <!-- CARD 1: Groceries -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:background="@drawable/bg_card_base" android:elevation="2dp">
                <View android:layout_width="4dp" android:layout_height="match_parent" android:background="@drawable/bg_left_border_blue" />
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/c3_title" style="@style/AppHeading" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentTop="true" android:layout_marginTop="4dp" android:layout_toStartOf="@+id/card_img_3" android:text="Groceries Delivery" android:textColor="@color/text_header" android:textSize="18sp" />
                    <TextView android:id="@+id/c3_price" style="@style/AppHeading" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c3_title" android:layout_marginTop="2dp" android:text="₹100" android:textColor="@color/brand_primary" android:textSize="15sp" />
                    <TextView android:id="@+id/c3_desc" style="@style/AppDescription" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c3_price" android:layout_toStartOf="@+id/card_img_3" android:layout_marginEnd="12dp" android:layout_marginTop="4dp" android:text="Need someone to pick up groceries from D-Mart." android:textColor="@color/text_subheadline" android:textSize="12sp" />
                    <ImageView android:id="@+id/card_img_3" android:layout_width="80dp" android:layout_height="80dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="@drawable/bg_image_placeholder" />
                </RelativeLayout>
            </FrameLayout>

            <!-- CARD 2: Plumbing -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:background="@drawable/bg_card_base" android:elevation="2dp">
                <View android:layout_width="4dp" android:layout_height="match_parent" android:background="@drawable/bg_left_border_blue" />
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/c1_title" style="@style/AppHeading" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Plumbing Repair" android:textColor="@color/text_header" android:textSize="18sp" />
                    <TextView android:id="@+id/c1_price" style="@style/AppHeading" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c1_title" android:layout_marginTop="2dp" android:text="₹400" android:textColor="@color/brand_primary" android:textSize="15sp" />
                    <TextView android:id="@+id/c1_desc" style="@style/AppDescription" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c1_price" android:layout_toStartOf="@+id/card_img_1" android:layout_marginEnd="12dp" android:layout_marginTop="4dp" android:text="Experienced plumber needed." android:textColor="@color/text_subheadline" android:textSize="12sp" />
                    <ImageView android:id="@+id/card_img_1" android:layout_width="80dp" android:layout_height="80dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="@drawable/bg_image_placeholder" />
                </RelativeLayout>
            </FrameLayout>

            <!-- CARD 3: Cleaning (New) -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:background="@drawable/bg_card_base" android:elevation="2dp">
                <View android:layout_width="4dp" android:layout_height="match_parent" android:background="@drawable/bg_left_border_red" />
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/c4_tag" style="@style/AppHeading" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="URGENT" android:textColor="@color/brand_error_solid" android:textSize="11sp" />
                    <TextView android:id="@+id/c4_title" style="@style/AppHeading" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c4_tag" android:layout_marginTop="4dp" android:text="Deep House Cleaning" android:textColor="@color/text_header" android:textSize="18sp" />
                    <TextView android:id="@+id/c4_price" style="@style/AppHeading" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c4_title" android:layout_marginTop="2dp" android:text="₹1500" android:textColor="@color/brand_primary" android:textSize="15sp" />
                    <TextView android:id="@+id/c4_desc" style="@style/AppDescription" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c4_price" android:layout_toStartOf="@+id/card_img_4" android:layout_marginEnd="12dp" android:layout_marginTop="4dp" android:text="Full 3BHK deep cleaning services required for move-in." android:textColor="@color/text_subheadline" android:textSize="12sp" />
                    <ImageView android:id="@+id/card_img_4" android:layout_width="80dp" android:layout_height="80dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="@drawable/bg_image_placeholder" />
                </RelativeLayout>
            </FrameLayout>

            <!-- CARD 4: Tuition (New) -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp" android:background="@drawable/bg_card_base" android:elevation="2dp">
                <View android:layout_width="4dp" android:layout_height="match_parent" android:background="@drawable/bg_left_border_blue" />
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/c5_title" style="@style/AppHeading" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Maths Tuition Class 10" android:textColor="@color/text_header" android:textSize="18sp" />
                    <TextView android:id="@+id/c5_price" style="@style/AppHeading" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c5_title" android:layout_marginTop="2dp" android:text="₹500/hour" android:textColor="@color/brand_primary" android:textSize="15sp" />
                    <TextView android:id="@+id/c5_desc" style="@style/AppDescription" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c5_price" android:layout_toStartOf="@+id/card_img_5" android:layout_marginEnd="12dp" android:layout_marginTop="4dp" android:text="Home tutoring for 10th grade student, Algebra focus." android:textColor="@color/text_subheadline" android:textSize="12sp" />
                    <ImageView android:id="@+id/card_img_5" android:layout_width="80dp" android:layout_height="80dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="@drawable/bg_image_placeholder" />
                </RelativeLayout>
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:text="Post Similar Task"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>









