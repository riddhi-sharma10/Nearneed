<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCFAFA"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- App Bar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back_arrow" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="POST DETAIL"
                    android:textColor="#101D33"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <ImageButton
                    android:id="@+id/btnOptions"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_dropdown_small" 
                    android:rotation="270"
                    app:tint="#101D33"/>
            </RelativeLayout>

            <!-- Hero Image Block (Pink Area) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FCE7F3"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="32dp"
                android:paddingBottom="32dp">

                <!-- Placeholder for Basket Image -->
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_circle_grey_solid"
                    android:src="@drawable/ic_check_solid_white"
                    app:tint="#F43F5E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Food Support"
                    android:textColor="#F43F5E"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- URGENT Banner -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F59E0B"
                android:gravity="center"
                android:padding="8dp"
                android:text="URGENT"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                app:drawableStartCompat="@drawable/ic_info_red"
                app:drawableTint="#FFFFFF"
                android:drawablePadding="8dp" />

            <!-- Content Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Emergency food delivery for senior"
                    android:textColor="#0F172A"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <!-- Meta Pills Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill_pink_transparent"
                        android:text="Food"
                        android:textColor="#F43F5E"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="5m ago"
                        android:textColor="#64748B"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="2 responses"
                        android:textColor="#64748B"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="0.4 km"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        app:drawableStartCompat="@drawable/ic_loc_pin_small"
                        app:drawableTint="#64748B"
                        android:drawablePadding="4dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Need 4 volunteers to help distribute meal kits to elderly neighbors in block 4 who are unable to leave home due to construction."
                    android:textColor="#475569"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

                <!-- Audio Block -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_card_audio"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="16dp">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_solid_red">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="#FFFFFF" />
                    </FrameLayout>

                    <!-- Dummy audio waves -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="24dp"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <View android:layout_width="2dp" android:layout_height="12dp" android:background="#FCA5A5" android:layout_marginEnd="4dp"/>
                        <View android:layout_width="2dp" android:layout_height="18dp" android:background="#F87171" android:layout_marginEnd="4dp"/>
                        <View android:layout_width="2dp" android:layout_height="14dp" android:background="#FCA5A5" android:layout_marginEnd="4dp"/>
                        <View android:layout_width="2dp" android:layout_height="24dp" android:background="#DC2626" android:layout_marginEnd="4dp"/>
                        <View android:layout_width="2dp" android:layout_height="16dp" android:background="#FCA5A5" android:layout_marginEnd="4dp"/>
                        <View android:layout_width="2dp" android:layout_height="20dp" android:background="#EF4444" android:layout_marginEnd="4dp"/>
                        <View android:layout_width="2dp" android:layout_height="12dp" android:background="#FCA5A5" android:layout_marginEnd="4dp"/>
                        <View android:layout_width="2dp" android:layout_height="8dp"  android:background="#FECDD3" android:layout_marginEnd="4dp"/>
                        <View android:layout_width="2dp" android:layout_height="4dp"  android:background="#FFE4E6" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:14"
                        android:textColor="#E11D48"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Volunteers Needed Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_card_outline"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="VOLUNTEERS NEEDED"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_pill_pink_transparent"
                            android:text="2 / 4 Filled"
                            android:textColor="#F43F5E"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_circle_solid_red"
                            android:src="@drawable/bg_image_placeholder" />

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_circle_solid_red"
                            android:src="@drawable/bg_image_placeholder" />

                         <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_dashed_circle_grey">
                             <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" android:textColor="#94A3B8" android:layout_gravity="center" android:textSize="18sp"/>
                         </FrameLayout>

                         <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_dashed_circle_grey">
                             <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" android:textColor="#94A3B8" android:layout_gravity="center" android:textSize="18sp"/>
                         </FrameLayout>

                    </LinearLayout>
                </LinearLayout>

                <!-- Location Block -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp">
                    
                    <TextView
                        android:id="@+id/c4_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:text="LOCATION"
                        android:textColor="#64748B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Koramangala 4th Block"
                        android:textColor="#101D33"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_below="@id/c4_location"
                        android:layout_marginTop="24dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_map_vector"
                        android:background="@drawable/bg_card_base"
                        android:clipToOutline="true" />
                </RelativeLayout>

                <!-- Management Buttons -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewVolunteers"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="48dp"
                    android:text="View Volunteers"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app:icon="@drawable/ic_forward_arrow"
                    app:iconGravity="textEnd"
                    app:iconTint="#FFFFFF"
                    app:backgroundTint="#F43F5E"
                    app:cornerRadius="12dp"
                    android:elevation="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewResponses"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="View Responses"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app:icon="@drawable/ic_forward_arrow"
                    app:iconGravity="textEnd"
                    app:iconTint="#FFFFFF"
                    app:backgroundTint="#E11D48"
                    app:cornerRadius="12dp"
                    android:elevation="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpdateStatus"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="Update Status"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app:icon="@drawable/ic_dropdown_small"
                    app:iconGravity="textEnd"
                    app:iconTint="#FFFFFF"
                    app:backgroundTint="#BE123C"
                    app:cornerRadius="12dp"
                    android:elevation="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRateVolunteers"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="Rate Volunteers"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:visibility="gone"
                    app:icon="@drawable/ic_forward_arrow"
                    app:iconGravity="textEnd"
                    app:iconTint="#FFFFFF"
                    app:backgroundTint="#881337"
                    app:cornerRadius="12dp"
                    android:elevation="0dp" />

            </LinearLayout>

            <!-- Bottom Margin space -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="48dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
