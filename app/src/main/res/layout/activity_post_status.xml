<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    tools:ignore="HardcodedText,ContentDescription">

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- App Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back_arrow"
                    app:tint="@color/brand_error_solid" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Back to Post"
                    android:textColor="@color/brand_error_solid"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Hero Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="8dp"
                android:text="Is this complete?"
                android:textColor="@color/text_header"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Active Request Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="@color/brand_error_bg"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACTIVE REQUEST"
                        android:textColor="@color/brand_error_solid"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Grocery Delivery for Elderly Neighbor"
                        android:textColor="@color/text_header"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Posted by Sarah Jenkins"
                        android:textColor="@color/text_subheadline"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Verification Card with Overlapping Avatar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="32dp">

                <!-- The Main Card Body -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeColor="@color/divider_soft"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:paddingBottom="24dp"
                        android:paddingTop="56dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Did Sarah help you?"
                            android:textColor="@color/text_header"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textAlignment="center" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Confirming completion will notify the community and award contribution points."
                            android:textColor="@color/text_subheadline"
                            android:textSize="14sp"
                            android:textAlignment="center"
                            android:lineSpacingExtra="4dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnYesHelped"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="24dp"
                            android:text="Yes, they helped"
                            android:textColor="@color/white"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/brand_error_solid"
                            app:cornerRadius="16dp"
                            android:elevation="0dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNotYet"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="12dp"
                            android:text="Not yet"
                            android:textColor="@color/text_subheadline"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/white"
                            app:strokeColor="@color/border_standard"
                            app:strokeWidth="1dp"
                            app:cornerRadius="16dp"
                            android:elevation="0dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- The Overlapping Avatar -->
                <RelativeLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_centerHorizontal="true"
                    android:background="@drawable/bg_circle_outline_pink"
                    android:padding="3dp"
                    android:elevation="4dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_circle_solid_red"
                        android:backgroundTint="@color/pagers_indicator_inactive"
                        android:src="@drawable/bg_image_placeholder" />
                </RelativeLayout>
            </RelativeLayout>

            <!-- Volunteer Completeness List -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="32dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/tagTotal"
                        android:layout_marginEnd="16dp"
                        android:layout_centerVertical="true"
                        android:text="Which volunteers have completed?"
                        android:textColor="@color/text_header"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tagTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_pill_pink_transparent"
                        android:text="3 SLOTS\nTOTAL"
                        android:textColor="@color/brand_error_solid"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textAlignment="center"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />
                </RelativeLayout>

                <!-- Card 1: Michael Chen -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeColor="@color/divider_soft"
                    app:strokeWidth="1dp">
                    
                    <LinearLayout
                        android:id="@+id/rowMichael"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_circle_solid_red"
                            android:backgroundTint="@color/brand_info_bg"
                            android:src="@drawable/bg_image_placeholder" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Michael Chen"
                                android:textColor="@color/text_header"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Volunteered 2 days ago"
                                android:textColor="@color/text_subheadline"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Empty Checkbox -->
                        <ImageView
                            android:id="@+id/cbMichael"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_card_outline" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card 2: Elena Rodriguez (Checked) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeColor="@color/divider_soft"
                    app:strokeWidth="1dp">
                    
                    <LinearLayout
                        android:id="@+id/rowElena"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_circle_solid_red"
                            android:backgroundTint="@color/brand_warning_bg_alt"
                            android:src="@drawable/bg_image_placeholder" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Elena Rodriguez"
                                android:textColor="@color/text_header"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Volunteered yesterday"
                                android:textColor="@color/text_subheadline"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Checked Checkbox -->
                        <ImageView
                            android:id="@+id/cbElena"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_circle_solid_red"
                            android:backgroundTint="@color/brand_error_solid"
                            android:padding="4dp"
                            android:src="@drawable/ic_check_solid_white" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card 3: David Wilson -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeColor="@color/divider_soft"
                    app:strokeWidth="1dp">
                    
                    <LinearLayout
                        android:id="@+id/rowDavid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_circle_solid_red"
                            android:backgroundTint="@color/brand_warning_bg_alt"
                            android:src="@drawable/bg_image_placeholder" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="David Wilson"
                                android:textColor="@color/text_header"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Volunteered 4 hours ago"
                                android:textColor="@color/text_subheadline"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Empty Checkbox -->
                        <ImageView
                            android:id="@+id/cbDavid"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_card_outline" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Bottom Actions -->
            <LinearLayout
                android:id="@+id/bottomActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="32dp"
                android:paddingBottom="24dp"
                android:background="@color/surface_background">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFinalUpdateStatus"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Update Status"
                    android:textColor="@color/white"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/text_header"
                    app:cornerRadius="16dp"
                    android:elevation="0dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Completed posts are archived after 24 hours."
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textAlignment="center" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>









