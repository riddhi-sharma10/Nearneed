<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F7F9FA">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

    <!-- Top Toolbar -->
    <ImageView
        android:id="@+id/iv_close"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:padding="12dp"
        android:src="@drawable/ic_close_rating"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rating Confirmation"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/iv_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/iv_close" />

    <!-- Outer yellow glow around the circle -->
    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_star_glow"
        app:layout_constraintBottom_toBottomOf="@+id/card_star"
        app:layout_constraintEnd_toEndOf="@+id/card_star"
        app:layout_constraintStart_toStartOf="@+id/card_star"
        app:layout_constraintTop_toTopOf="@+id/card_star" />

    <!-- Center Icon -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_star"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="56dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="60dp"
        app:cardElevation="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_title">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_star_rating" />
    </androidx.cardview.widget.CardView>

    <!-- Texts -->
    <TextView
        android:id="@+id/tv_rating_submitted"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Rating submitted."
        android:textColor="#000000"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/card_star" />

    <TextView
        android:id="@+id/tv_score_updated"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Rahul S.'s Neighbour Score has been\nupdated."
        android:textColor="#5F6368"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_rating_submitted" />

    <!-- Pill -->
    <TextView
        android:id="@+id/tv_waiting_rating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_pill_waiting"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:text="Waiting for Rahul S. to rate you."
        android:textColor="#1A73E8"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_score_updated" />

    <!-- Gig Image Map/Placeholder -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_gig_image"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_waiting_rating">

        <ImageView
            android:id="@+id/iv_gig_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_rounded_rect_placeholder"
            android:scaleType="centerCrop" />

        <!-- Gradient Scrim for text visibility over image -->
        <View
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_scrim_bottom" />

        <TextView
            android:id="@+id/tv_gig_completed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="16dp"
            android:text="Gig completed with Rahul S."
            android:textColor="@android:color/white"
            android:textSize="14sp" />
    </androidx.cardview.widget.CardView>

    <!-- Progress section -->
    <TextView
        android:id="@+id/tv_auto_redirect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="24dp"
        android:text="AUTO-REDIRECTING"
        android:textColor="#9AA0A6"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        app:layout_constraintTop_toBottomOf="@+id/card_gig_image"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_redirect_seconds"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="24dp"
        android:text="3S"
        android:textColor="#9AA0A6"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/card_gig_image"
        app:layout_constraintEnd_toEndOf="parent" />

    <ProgressBar
        android:id="@+id/pb_redirect"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="12dp"
        android:max="100"
        android:progress="66"
        android:progressDrawable="@drawable/bg_progress_bar"
        app:layout_constraintTop_toBottomOf="@+id/tv_auto_redirect"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_back_feed"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_btn_primary"
        android:text="Back to Feed"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/pb_redirect"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="1.0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
