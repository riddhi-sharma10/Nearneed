<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Back + Title -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back_arrow" />

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="New Community Post"
                    android:textColor="@color/text_header"
                    android:textSize="16sp" />
            </RelativeLayout>

            <!-- Progress Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal"
                android:weightSum="1"
                android:gravity="center_vertical">
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Step 2 of 2"
                    android:textColor="@color/text_header"
                    android:textSize="14sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="@color/brand_error_solid"
                    android:textSize="12sp"
                    style="@style/AppHeading" />
            </LinearLayout>
            <ProgressBar
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="8dp"
                android:progress="100"
                android:max="100"
                android:progressDrawable="@drawable/bg_progress_bar_red_flat" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Add a photo, voice note, and your location details."
                android:textColor="@color/text_subheadline"
                android:textSize="16sp" />

            <!-- ── ADD PHOTOS ── -->
            <TextView
                style="@style/AppHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="ADD PHOTOS"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:letterSpacing="0.1" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Add button -->
                    <LinearLayout
                        android:id="@+id/btnAddPhoto"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_district_pill_input_white_stroke"
                        android:elevation="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_camera_blue"
                            app:tint="@color/brand_error_solid"
                            android:importantForAccessibility="no" />

                        <TextView
                            style="@style/AppHeading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ADD"
                            android:textColor="@color/brand_error_solid"
                            android:textSize="11sp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- Photo slot 1 -->
                    <ImageView
                        android:id="@+id/ivPhoto1"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_image_placeholder"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_card_base"
                        android:elevation="4dp"
                        android:visibility="gone" />

                    <!-- Photo slot 2 -->
                    <ImageView
                        android:id="@+id/ivPhoto2"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_image_placeholder"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_card_base"
                        android:elevation="4dp"
                        android:visibility="gone" />

                    <!-- Photo slot 3 -->
                    <ImageView
                        android:id="@+id/ivPhoto3"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_image_placeholder"
                        android:background="@drawable/bg_card_base"
                        android:elevation="4dp"
                        android:visibility="gone" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- ── VOICE NOTE ── -->
            <TextView
                style="@style/AppHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="VOICE NOTE"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:letterSpacing="0.1" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_district_pill_input_white_stroke"
                android:elevation="6dp"
                android:padding="16dp">

                <FrameLayout
                    android:id="@+id/iconVoiceContainer"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_circle_pink"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true">
                    <ImageView
                        android:id="@+id/ivVoiceStatus"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_mic_blue"
                        app:tint="@color/brand_error_solid" />
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/textContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/iconVoiceContainer"
                    android:layout_toStartOf="@+id/actionContainer"
                    android:layout_marginStart="14dp"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvVoiceTitle"
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Record details"
                        android:textColor="@color/text_header"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvVoiceSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Record a 20-second voice note"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/btnStartRecording"
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Start"
                        android:textColor="@color/brand_error_solid"
                        android:textSize="13sp"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <LinearLayout
                        android:id="@+id/playerControls"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="gone">
                        
                        <ImageView
                            android:id="@+id/btnPlayAudio"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_check_circle_green"
                            app:tint="@color/brand_error_solid"
                            android:padding="4dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <ImageView
                            android:id="@+id/btnDeleteAudio"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_close_grey"
                            app:tint="@color/brand_error_solid"
                            android:padding="4dp"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>

            <!-- ── LOCATION ── -->
            <TextView
                style="@style/AppHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="LOCATION"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:letterSpacing="0.1" />

            <RelativeLayout
                android:id="@+id/cardLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_district_pill_input_white_stroke"
                android:elevation="6dp"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/ivMapThumbnail"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/bg_map_vector"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_card_base"
                    android:importantForAccessibility="no" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toStartOf="@id/ivMapThumbnail"
                    android:layout_marginEnd="12dp"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BML Munjal University"
                        android:textColor="@color/text_header"
                        android:textSize="14sp"
                        app:drawableStartCompat="@drawable/ic_loc_pin_small"
                        app:drawableTint="@color/brand_error_solid"
                        android:drawablePadding="6dp"
                        android:gravity="center_vertical" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:layout_marginStart="20dp"
                        android:text="Kazhean, Haryana"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />

                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="20dp"
                        android:text="Tap to adjust ✎"
                        android:textColor="@color/brand_error_solid"
                        android:textSize="12sp" />
                </LinearLayout>
            </RelativeLayout>

            <!-- ── WHEN DO YOU NEED THIS? ── -->
            <TextView
                style="@style/AppHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="WHEN DO YOU NEED THIS?"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/chipWhenToday"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Today"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:background="@drawable/bg_chip_selected_red"
                    android:layout_marginEnd="10dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipWhenThisWeek"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="This week"
                    android:textColor="@color/text_subheadline"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:layout_marginEnd="10dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipWhenFlexible"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Flexible"
                    android:textColor="@color/text_subheadline"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="24dp" />

            <!-- District-Style CTA -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPostNow"
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Post Now"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="@color/brand_error_solid"
                app:cornerRadius="16dp"
                android:elevation="0dp"
                android:layout_marginBottom="32dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
