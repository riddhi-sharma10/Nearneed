<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="24dp"
    android:layout_margin="24dp"
    android:gravity="center_horizontal">

    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_circle_pink"
        android:layout_marginTop="16dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_bell_outline_red"
            android:importantForAccessibility="no" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvEmergencyDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/txt_emergency_post_title"
        android:textColor="@color/text_header"
        android:textSize="18sp"
        android:textAlignment="center"
        style="@style/AppHeading" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/txt_emergency_post_desc"
        android:textColor="@color/text_subheadline"
        android:textSize="13sp"
        android:textAlignment="center"
        android:paddingHorizontal="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="32dp"
        android:background="@color/divider_soft" />

    <TextView
        android:id="@+id/btnEmergencyPost"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/txt_btn_emergency_post"
        android:textColor="@color/brand_error_solid"
        android:textSize="16sp"
        style="@style/AppHeading"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_soft" />

    <TextView
        android:id="@+id/btnCommunityPost"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/txt_btn_community_post"
        android:textColor="@color/brand_warning_solid"
        android:textSize="16sp"
        style="@style/AppHeading"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_soft" />

    <TextView
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/txt_btn_cancel"
        android:textColor="@color/text_header"
        android:textSize="16sp"
        style="@style/AppHeading"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground" />

</LinearLayout>
