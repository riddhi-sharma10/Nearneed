<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- 1. IMMERSIVE MAP BACKGROUND -->
    <FrameLayout
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/bg_map_vector"
            android:scaleType="centerCrop"
            android:alpha="0.4"
            app:tint="#F1F5F9" />

        <!-- Need Pin (Food) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:layout_marginTop="60dp"
            android:layout_marginStart="120dp"
            android:background="@drawable/bg_immersive_pin_need"
            android:elevation="6dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍎 Food"
                android:textColor="#F43F5E"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Need Pin (Tools) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:layout_marginTop="-40dp"
            android:layout_marginStart="140dp"
            android:background="@drawable/bg_immersive_pin_need"
            android:elevation="6dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚒️ Tools"
                android:textColor="#F43F5E"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- User "YOU" Pin (Pink Version) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_horizontal"
            android:orientation="vertical">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/bg_image_placeholder"
                android:background="@drawable/bg_circle_solid_red"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:elevation="4dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_btn_light_red"
                android:paddingHorizontal="8dp"
                android:paddingVertical="1dp"
                android:text="YOU"
                android:textColor="#F43F5E"
                android:textSize="8sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <!-- 3. TOP SOPHISTICATED HEADER (SEARCHBAR STYLE) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:paddingHorizontal="16dp"
        android:gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_immersive_header"
            android:elevation="8dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">
            
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/bg_image_placeholder"
                android:background="@drawable/bg_circle_solid_red"
                android:padding="1dp"
                android:scaleType="centerCrop" />
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Koramangala - 2 km"
                    android:textColor="#101D33"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● LIVE LOCATION"
                    android:textColor="#22C55E"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search_grey"
                app:tint="#94A3B8" />
        </LinearLayout>
    </LinearLayout>

    <!-- 4. FLOATING MAP CONTROLS -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|top"
        android:layout_marginTop="120dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        android:gravity="center">
        
        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_plus_white"
            app:tint="#101D33"
            android:background="@drawable/bg_circle_solid_white"
            android:padding="12dp"
            android:elevation="6dp"/>
        
        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_layers"
            app:tint="#101D33"
            android:background="@drawable/bg_circle_solid_white"
            android:padding="12dp"
            android:elevation="6dp"/>

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_loc_pin_small"
            app:tint="#101D33"
            android:background="@drawable/bg_circle_solid_white"
            android:padding="12dp"
            android:elevation="6dp"/>
    </LinearLayout>

    <!-- 5. PIN PREVIEW MODAL -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPinPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="16dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/ivUserAvatar"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/bg_image_placeholder"
                    android:background="@drawable/bg_circle_solid_red"
                    android:padding="2dp"
                    android:scaleType="centerCrop"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ivUserAvatar"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Priya M. • VERIFIED"
                        android:textColor="#101D33"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.9★ • Neighbour Score • 1.2 km"
                        android:textColor="#64748B"
                        android:textSize="11sp" />
                </LinearLayout>
                <ImageView
                    android:id="@+id/btnClosePreview"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/ic_close_grey"
                    android:background="@drawable/bg_circle_grey_solid"
                    android:padding="8dp" />
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_pill_pink_transparent"
                android:backgroundTint="#FEF3C7"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="URGENT"
                android:textColor="#D97706"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Need spare oxygen cylinder"
                android:textColor="#101D33"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <TextView
                    android:id="@+id/tvPricePreview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text=""
                    android:textColor="#F43F5E"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvProgressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 / 4 needed"
                    android:textColor="#64748B"
                    android:textSize="12sp" />
                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="200dp"
                    android:layout_height="6dp"
                    android:layout_below="@+id/tvProgressText"
                    android:layout_marginTop="8dp"
                    android:progress="50"
                    android:progressTint="#F43F5E"
                    android:progressBackgroundTint="#F1F5F9" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">
                
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewFullPost"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="56dp"
                    android:text="View Full Post →"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    app:backgroundTint="#F43F5E"
                    app:cornerRadius="16dp" />

                <ImageButton
                    android:id="@+id/btnQuickRespond"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_message_grey"
                    app:tint="#64748B"
                    android:background="@drawable/bg_card_outline" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
