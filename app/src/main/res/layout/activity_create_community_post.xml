<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background_clean"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ── HEADER / BACK BUTTON ── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back_arrow" />

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Create Community Post"
                    android:textColor="@color/text_header"
                    android:textSize="16sp" />
            </RelativeLayout>

            <!-- ── PROGRESS BAR ── -->
            <TextView
                style="@style/AppHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Step 1 of 2"
                android:textColor="@color/brand_error_solid"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:weightSum="1"
                android:gravity="center_vertical"
                android:baselineAligned="false">
                            <TextView
                                style="@style/AppHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="50%"
                    android:textColor="@color/brand_error_solid"
                    android:textSize="14sp" />
            </LinearLayout>

            <ProgressBar
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="8dp"
                android:progress="50"
                android:max="100"
                android:progressDrawable="@drawable/bg_progress_bar_red_flat" />

            <!-- ── WHAT DO YOU NEED? ── -->
            <TextView
                style="@style/AppHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="WHAT DO YOU NEED?"
                android:textColor="@color/text_subheadline"
                android:textSize="10sp"
                android:letterSpacing="0.05" />

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_district_pill_input_white_stroke"
                android:elevation="6dp"
                android:outlineAmbientShadowColor="@color/shadow_ambient"
                android:outlineSpotShadowColor="@color/shadow_spot"
                android:hint="Enter your request title"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_header"
                android:textSize="16sp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:inputType="text"
                android:autofillHints="none" />

            <!-- ── TELL YOUR NEIGHBOURS MORE ── -->
            <TextView
                style="@style/AppHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="TELL YOUR NEIGHBOURS MORE"
                android:textColor="@color/text_subheadline"
                android:textSize="10sp"
                android:letterSpacing="0.05" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_district_pill_input_white_stroke"
                android:elevation="6dp"
                android:outlineAmbientShadowColor="@color/shadow_ambient"
                android:outlineSpotShadowColor="@color/shadow_spot"
                android:hint="Provide more details about your request"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_header"
                android:textSize="16sp"
                android:padding="20dp"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:autofillHints="none" />

            <!-- ── URGENCY ── -->
            <TextView
                style="@style/AppHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="URGENCY"
                android:textColor="@color/text_subheadline"
                android:textSize="10sp"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:id="@+id/urgencyNormal"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_urgency_unselected"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_dot_green" />

                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Normal"
                        android:textColor="@color/text_header"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp" />
                        
                    <TextView
                        style="@style/AppDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="48h expiry"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/urgencyUrgent"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_urgency_selected"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_dot_orange" />

                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Urgent"
                        android:textColor="@color/brand_warning_text"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp" />
                        
                    <TextView
                        style="@style/AppDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6h expiry"
                        android:textColor="@color/brand_warning_text_alt"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/urgencyEmergency"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_urgency_unselected"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_dot_red" />

                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Emergency"
                        android:textColor="@color/text_header"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp" />
                        
                    <TextView
                        style="@style/AppDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2h expiry"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── EMERGENCY WARNING ALERT ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_alert_red"
                android:padding="16dp"
                android:layout_marginTop="16dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_info_red"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="@style/AppDescription"
                    android:text="Emergency will send SMS to all neighbours in your radius, even on silent."
                    android:textColor="@color/brand_error_text"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>

            <!-- ── CATEGORY ── -->
            <TextView
                style="@style/AppHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="CATEGORY"
                android:textColor="@color/text_subheadline"
                android:textSize="10sp"
                android:letterSpacing="0.05" />

            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Medical"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_red"
                    app:chipStrokeColor="@color/sel_chip_stroke_red"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_red" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Food"
                    android:checked="true"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_red"
                    app:chipStrokeColor="@color/sel_chip_stroke_red"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_red" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Transport"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_red"
                    app:chipStrokeColor="@color/sel_chip_stroke_red"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_red" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Tools"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_red"
                    app:chipStrokeColor="@color/sel_chip_stroke_red"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_red" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Shelter"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_red"
                    app:chipStrokeColor="@color/sel_chip_stroke_red"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_red" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Information"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_red"
                    app:chipStrokeColor="@color/sel_chip_stroke_red"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_red" />
                    
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Other"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_red"
                    app:chipStrokeColor="@color/sel_chip_stroke_red"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_red" />
            </com.google.android.material.chip.ChipGroup>

            <!-- ── VOLUNTEERS ── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_district_pill_input_white_stroke"
                android:elevation="6dp"
                android:outlineAmbientShadowColor="@color/shadow_ambient"
                android:outlineSpotShadowColor="@color/shadow_spot"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:gravity="start">

                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VOLUNTEERS"
                        android:textColor="@color/text_subheadline"
                        android:textSize="10sp"
                        android:letterSpacing="0.05" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/btnVolMinus"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="−"
                            android:textColor="@color/brand_error_solid"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:background="@drawable/bg_alert_red"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/tvVolCount"
                            style="@style/AppHeading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1"
                            android:textColor="@color/text_header"
                            android:textSize="18sp"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp" />

                        <TextView
                            android:id="@+id/btnVolPlus"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="+"
                            android:textColor="@color/brand_error_solid"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:background="@drawable/bg_alert_red"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:gravity="end">
                    
                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SET MAXIMUM"
                        android:textColor="@color/text_muted"
                        android:textSize="8sp"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="4dp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchMaxVolunteers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="@color/brand_error_solid"
                        app:trackTint="@color/brand_error_track" />
                </LinearLayout>

            </RelativeLayout>

            <!-- ── EXPIRES BANNER ── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_alert_yellow"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_alarm_orange"
                        android:layout_marginEnd="8dp" />
                        
                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EXPIRES IN 6 HOURS"
                        android:textColor="@color/brand_warning_text"
                        android:textSize="12sp" />
                </LinearLayout>
                
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="Change"
                    android:textColor="@color/brand_warning_text_alt"
                    android:textSize="11sp" />
            </RelativeLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="32dp" />

            <!-- ── CTA BUTTON ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinueCommunity"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Continue"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:icon="@drawable/ic_forward_arrow"
                app:iconGravity="textEnd"
                app:iconTint="@color/white"
                app:backgroundTint="@color/brand_error_solid"
                app:cornerRadius="16dp"
                android:elevation="0dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>









