<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    android:paddingTop="48dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="120dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white">

            <!-- Top Header -->
            <RelativeLayout
                android:id="@+id/headerLayout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back_arrow" />
                    
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Profile"
                    android:textColor="@color/text_header"
                    android:textSize="18sp" />

            </RelativeLayout>


            <!-- Card Wrap for Top section -->


            <!-- Neighbour Score -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/bg_card_base"
                android:elevation="6dp"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:outlineSpotShadowColor="@color/border_standard"
                android:paddingBottom="24dp">

                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginTop="24dp">

                    <ImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_circle_solid_white"
                        android:src="@drawable/bg_image_placeholder" />

                    <!-- Green Dot Status -->
                    <View
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/bg_dot_green" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Abhinav Oberoi"
                        android:textColor="@color/text_header"
                        android:textSize="22sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_verified_badge" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_loc_pin_small"
                        app:tint="@color/text_muted" />

                    <TextView
                        style="@style/AppDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Koramangala, Bangalore"
                        android:textColor="@color/text_subheadline"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Member since Jan 2024"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvPhoneNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="+91 98XXXXXX05"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditProfile"
                    style="@style/AppHeading"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginTop="20dp"
                    android:elevation="0dp"
                    android:text="Edit Profile"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    app:backgroundTint="@color/brand_primary"
                    app:cornerRadius="16dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_card_base"
                android:elevation="6dp"
                android:outlineSpotShadowColor="@color/border_standard"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    
                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NEIGHBOUR SCORE"
                        android:textColor="@color/text_subheadline"
                        android:textSize="10sp"
                        android:letterSpacing="0.05" />
                        
                    <TextView
                        android:id="@+id/btnViewReviews"
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="View Reviews"
                        android:textColor="@color/brand_primary"
                        android:textSize="11sp" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical">
                    
                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.8"
                        android:textColor="@color/text_header"
                        android:textSize="24sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:orientation="horizontal">
                        <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_yellow" />
                        <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_yellow" />
                        <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_yellow" />
                        <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_yellow" />
                        <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_yellow" app:tint="@color/pagers_indicator_inactive" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 3 Cols -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:weightSum="3">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            style="@style/AppHeading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12"
                            android:textColor="@color/text_header"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Gigs Done"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/divider_soft" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            style="@style/AppHeading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8"
                            android:textColor="@color/text_header"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Help Acts"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/divider_soft" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            style="@style/AppHeading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15"
                            android:textColor="@color/text_header"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Reviews"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Recent Activity -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RECENT ACTIVITY"
                    android:textColor="@color/text_header"
                    android:textSize="12sp"
                    android:letterSpacing="0.05" />
                <TextView
                    android:id="@+id/btnSeeAllActivity"
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="See All"
                    android:textColor="@color/brand_primary"
                    android:textSize="12sp" />
            </RelativeLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:clipToPadding="false"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Watered Plants Card -->
                    <LinearLayout
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_base"
                        android:elevation="4dp"
                        android:outlineSpotShadowColor="@color/border_standard"
                        android:orientation="vertical"
                        android:padding="16dp">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_cleaning" 
                            app:tint="@color/brand_info_vibrant"/>

                        <TextView
                            style="@style/AppHeading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Watered Plants"
                            android:textColor="@color/text_header"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="2 days ago • Paid Gig"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Grocery Run Card -->
                    <LinearLayout
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:background="@drawable/bg_card_base"
                        android:elevation="4dp"
                        android:outlineSpotShadowColor="@color/border_standard"
                        android:orientation="vertical"
                        android:padding="16dp">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_groceries" 
                            app:tint="@color/brand_warning_alt"/>

                        <TextView
                            style="@style/AppHeading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Grocery Run"
                            android:textColor="@color/text_header"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="4 days ago • Help Act"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Options List Menu -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/bg_card_base"
                android:elevation="6dp"
                android:outlineSpotShadowColor="@color/border_standard">

                <!-- My Posts -->
                <LinearLayout
                    android:id="@+id/btnMyPosts"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_bg_house" app:tint="@color/text_subheadline"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="My Posts"
                        android:textColor="@color/text_secondary_dark"
                        android:textSize="14sp"
                        style="@style/AppHeading" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_forward_arrow" app:tint="@color/pagers_indicator_inactive" />
                </LinearLayout>
                
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_soft" android:layout_marginStart="52dp"/>

                <!-- Saved Tasks -->
                <LinearLayout
                    android:id="@+id/btnSavedTasks"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_pin_white" app:tint="@color/text_subheadline"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="Saved Tasks"
                        android:textColor="@color/text_secondary_dark"
                        android:textSize="14sp"
                        style="@style/AppHeading" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_forward_arrow" app:tint="@color/pagers_indicator_inactive" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_soft" android:layout_marginStart="52dp"/>

                <!-- Help & Support -->
                <LinearLayout
                    android:id="@+id/btnHelpSupport"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_info_circle" app:tint="@color/text_subheadline"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="Help &amp; Support"
                        android:textColor="@color/text_secondary_dark"
                        android:textSize="14sp"
                        style="@style/AppHeading" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_forward_arrow" app:tint="@color/pagers_indicator_inactive" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_soft" android:layout_marginStart="52dp"/>

                <!-- Settings -->
                <LinearLayout
                    android:id="@+id/btnSettings"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_solid_wrench" app:tint="@color/text_subheadline"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="Settings"
                        android:textColor="@color/text_secondary_dark"
                        android:textSize="14sp"
                        style="@style/AppHeading" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_forward_arrow" app:tint="@color/pagers_indicator_inactive" />
                </LinearLayout>

            </LinearLayout>

            <!-- Logout Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="40dp"
                android:text="Logout"
                android:textColor="@color/brand_error_solid"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:backgroundTint="@color/brand_error_bg_light"
                app:cornerRadius="16dp"
                android:elevation="0dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="@color/divider_soft" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Universal Navigation System -->
    <include layout="@layout/layout_universal_navbar" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>









