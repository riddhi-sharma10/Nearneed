<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <!-- Top Header Spacer -->
    <View android:layout_width="match_parent" android:layout_height="60dp" android:background="#FFFFFF" />

    <!-- Top Header -->
    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp">
        <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:layout_centerVertical="true" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_back_arrow" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" android:text="My Posts" android:textColor="#101D33" android:textSize="18sp" android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">

            <!-- POST 1: Food Delivery -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:background="@drawable/bg_card_base" android:elevation="2dp">
                <View android:layout_width="4dp" android:layout_height="match_parent" android:background="@drawable/bg_left_border_red" />
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/c4_tag" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="URGENT" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" android:background="@drawable/bg_tag_urgent" android:paddingStart="6dp" android:paddingEnd="6dp" android:paddingTop="3dp" android:paddingBottom="3dp" />
                    <TextView android:id="@+id/c4_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c4_tag" android:layout_marginTop="8dp" android:layout_toStartOf="@+id/card_img_4" android:text="Emergency Food Delivery" android:textColor="#0F172A" android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:id="@+id/c4_sub" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c4_title" android:layout_marginTop="2dp" android:text="Food Support • 0/4 Volunteers" android:textColor="#64748B" android:textSize="12sp" />
                    <ImageView android:id="@+id/card_img_4" android:layout_width="80dp" android:layout_height="80dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="@drawable/bg_image_placeholder" />
                </RelativeLayout>
            </FrameLayout>

            <!-- POST 2: Plumbing -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:background="@drawable/bg_card_base" android:elevation="2dp">
                <View android:layout_width="4dp" android:layout_height="match_parent" android:background="@drawable/bg_left_border_blue" />
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/c1_tag" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PAID GIG" android:textColor="#1D5EF3" android:textSize="11sp" android:textStyle="bold" />
                    <TextView android:id="@+id/c1_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c1_tag" android:layout_marginTop="4dp" android:layout_toStartOf="@+id/card_img_1" android:text="Plumbing Repair" android:textColor="#0F172A" android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:id="@+id/c1_price" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c1_title" android:layout_marginTop="2dp" android:text="₹400 orçamento" android:textColor="#1D5EF3" android:textSize="14sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c1_price" android:layout_marginTop="8dp" android:text="3 applicants" android:textColor="#64748B" android:textSize="11sp" />
                    <ImageView android:id="@+id/card_img_1" android:layout_width="80dp" android:layout_height="80dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="@drawable/bg_image_placeholder" />
                </RelativeLayout>
            </FrameLayout>

            <!-- POST 3: Garden Cleanup (New) -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:background="@drawable/bg_card_base" android:elevation="2dp">
                <View android:layout_width="4dp" android:layout_height="match_parent" android:background="@drawable/bg_left_border_blue" />
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/c2_tag" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="COMMUNITY ACT" android:textColor="#1D5EF3" android:textSize="11sp" android:textStyle="bold" />
                    <TextView android:id="@+id/c2_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c2_tag" android:layout_marginTop="4dp" android:layout_toStartOf="@+id/card_img_2" android:text="Garden Drive Block B" android:textColor="#0F172A" android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:id="@+id/c2_stat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c2_title" android:layout_marginTop="2dp" android:text="Active • 12 Volunteers Joined" android:textColor="#10B981" android:textSize="12sp" />
                    <ImageView android:id="@+id/card_img_2" android:layout_width="80dp" android:layout_height="80dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="@drawable/bg_image_placeholder" />
                </RelativeLayout>
            </FrameLayout>

            <!-- POST 4: House Help (New) -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:background="@drawable/bg_card_base" android:elevation="2dp">
                <View android:layout_width="4dp" android:layout_height="match_parent" android:background="@drawable/bg_left_border_blue" />
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/c3_tag" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PAID GIG" android:textColor="#1D5EF3" android:textSize="11sp" android:textStyle="bold" />
                    <TextView android:id="@+id/c3_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c3_tag" android:layout_marginTop="4dp" android:layout_toStartOf="@+id/card_img_3" android:text="Dog Walking (Eve)" android:textColor="#0F172A" android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:id="@+id/c3_price" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c3_title" android:layout_marginTop="2dp" android:text="₹200/walk" android:textColor="#1D5EF3" android:textSize="14sp" android:textStyle="bold" />
                    <ImageView android:id="@+id/card_img_3" android:layout_width="80dp" android:layout_height="80dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="@drawable/bg_image_placeholder" />
                </RelativeLayout>
            </FrameLayout>

            <!-- POST 5: Car Wash (New/Filling Space) -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:background="@drawable/bg_card_base" android:elevation="2dp">
                <View android:layout_width="4dp" android:layout_height="match_parent" android:background="@drawable/bg_left_border_blue" />
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/c5_tag" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PAID GIG" android:textColor="#1D5EF3" android:textSize="11sp" android:textStyle="bold" />
                    <TextView android:id="@+id/c5_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c5_tag" android:layout_marginTop="4dp" android:layout_toStartOf="@+id/card_img_5" android:text="Car Wash Weekly" android:textColor="#0F172A" android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:id="@+id/c5_price" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/c5_title" android:layout_marginTop="2dp" android:text="₹300" android:textColor="#1D5EF3" android:textSize="14sp" android:textStyle="bold" />
                    <ImageView android:id="@+id/card_img_5" android:layout_width="80dp" android:layout_height="80dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="@drawable/bg_image_placeholder" />
                </RelativeLayout>
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                android:text="Create New Post"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:backgroundTint="#1D5EF3"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_plus_white"
                app:iconGravity="textStart" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
