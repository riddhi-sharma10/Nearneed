<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="64dp"
            android:gravity="center_horizontal">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:layout_centerVertical="true" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_back_arrow" />
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="ID Verification"
                    android:textColor="@color/text_header"
                    android:textSize="16sp" />
            </RelativeLayout>

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginTop="48dp"
                android:src="@drawable/ic_verified_badge" 
                app:tint="@color/brand_primary"/>

            <TextView
                style="@style/AppHero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Verify your identity"
                android:textColor="@color/text_header"
                android:textSize="28sp"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="NearNeed requires ID verification before you can post or apply for gigs."
                android:textColor="@color/text_subheadline"
                android:textSize="16sp"
                android:gravity="center"
                android:paddingHorizontal="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_verified_blue_shield"
                android:padding="20dp"
                android:orientation="vertical">
                
                <TextView 
                    style="@style/AppHeading"
                    android:layout_width="wrap_content" 
                    android:layout_height="wrap_content" 
                    android:text="WHY VERIFY?" 
                    android:textColor="@color/brand_primary" 
                    android:textSize="10sp" 
                    android:letterSpacing="0.05" />

                <TextView 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:layout_marginTop="4dp"
                    android:text="• Build deep trust with neighbors \n• Get a verified badge on your profile \n• Access high-reward Gigs and special tasks"
                    android:textColor="@color/text_header" 
                    android:textSize="12sp" 
                    android:lineSpacingExtra="2dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/brand_info_bg" android:layout_marginVertical="12dp" />

                <TextView 
                    style="@style/AppHeading"
                    android:layout_width="wrap_content" 
                    android:layout_height="wrap_content" 
                    android:text="ACCEPTED IDS" 
                    android:textColor="@color/brand_primary" 
                    android:textSize="10sp" 
                    android:letterSpacing="0.05" />

                <TextView 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:layout_marginTop="4dp"
                    android:text="Aadhaar, PAN, Driving Licenses, Voter ID, Passport" 
                    android:textColor="@color/text_header" 
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Front Side Upload -->
            <LinearLayout
                android:id="@+id/cardUploadFront"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_dashed_border"
                android:elevation="4dp"
                android:outlineAmbientShadowColor="@color/shadow_subtle"
                android:outlineSpotShadowColor="@color/shadow_subtle"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_id_camera" app:tint="@color/brand_primary" />
                <TextView 
                    style="@style/AppHeading"
                    android:layout_width="wrap_content" 
                    android:layout_height="wrap_content" 
                    android:text="Front of ID" 
                    android:textColor="@color/text_header" 
                    android:textSize="14sp" 
                    android:layout_marginTop="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Clear picture, no light reflections." android:textColor="@color/text_muted" android:textSize="12sp" />
            </LinearLayout>

            <!-- Back Side Upload -->
            <LinearLayout
                android:id="@+id/cardUploadBack"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_dashed_border"
                android:elevation="4dp"
                android:outlineAmbientShadowColor="@color/shadow_subtle"
                android:outlineSpotShadowColor="@color/shadow_subtle"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_id_camera" app:tint="@color/brand_primary" />
                <TextView 
                    style="@style/AppHeading"
                    android:layout_width="wrap_content" 
                    android:layout_height="wrap_content" 
                    android:text="Back of ID" 
                    android:textColor="@color/text_header" 
                    android:textSize="14sp" 
                    android:layout_marginTop="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Clear picture, horizontally held." android:textColor="@color/text_muted" android:textSize="12sp" />
            </LinearLayout>
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical">
                <CheckBox
                    android:id="@+id/cbTerms"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:button="@drawable/sel_custom_checkbox"
                    android:padding="0dp"
                    android:layout_gravity="center_vertical" />
                <TextView 
                    android:id="@+id/tvTermsLink"
                    android:layout_width="wrap_content" 
                    android:layout_height="wrap_content" 
                    android:layout_marginStart="4dp" 
                    android:text="I agree to the Terms, Conditions and Guidelines" 
                    android:textColor="@color/text_subheadline" 
                    android:textSize="12sp" />
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmit"
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Submit for Verification"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:backgroundTint="@color/brand_info_accent_light"
                app:cornerRadius="16dp"
                android:elevation="0dp" />
                
            <TextView
                android:id="@+id/btnSkip"
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:text="Skip for now"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
