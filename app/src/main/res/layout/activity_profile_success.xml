<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B3000000"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <!-- Bottom Sheet Container -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardElevation="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Green Identity Verified icon -->
            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_verified_badge" 
                    app:tint="#10B981"/> <!-- Green -->
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Identity Verified"
                android:textColor="#101D33"
                android:textSize="24sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="You're all set up! A verified badge has been added to your profile to ensure trust."
                android:textColor="#64748B"
                android:textSize="14sp"
                android:gravity="center"
                android:paddingHorizontal="16dp"/>

            <!-- Identity Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_district_pill_input_white_stroke"
                android:elevation="6dp"
                android:outlineAmbientShadowColor="#0F000000"
                android:outlineSpotShadowColor="#1A000000"
                android:padding="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bg_image_placeholder" />
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Abhinav Sharma" android:textColor="#101D33" android:textSize="16sp" android:textStyle="bold" />
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_verified_badge" android:layout_marginStart="6dp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BML Munjal Univ | Joined Oct 2024" android:textColor="#94A3B8" android:textSize="12sp" android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDone"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:text="Continue"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#1D5EF3"
                app:cornerRadius="16dp"
                android:elevation="0dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>