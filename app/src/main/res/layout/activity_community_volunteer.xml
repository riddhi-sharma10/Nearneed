<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:ignore="HardcodedText,ContentDescription">

    <!-- App Bar -->
    <RelativeLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back_arrow"
            app:tint="@color/text_header" />

        <TextView
            style="@style/AppHeading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Details"
            android:textColor="@color/text_header"
            android:textSize="18sp" />

        <ImageButton
            android:id="@+id/btnShare"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/btnOptions"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_share"
            app:tint="@color/text_header" />

        <ImageButton
            android:id="@+id/btnOptions"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_dots"
            app:tint="@color/text_header" />

    </RelativeLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomCta"
        app:layout_constraintTop_toBottomOf="@id/appBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Hero Image -->
            <ImageView
                android:id="@+id/ivHero"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:scaleType="centerCrop"
                android:src="@drawable/img_immersive_map" />

            <!-- Progress Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SLOTS AVAILABLE"
                        android:textColor="@color/text_subheadline"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="1 spot remaining"
                        android:textColor="@color/brand_error_solid"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <ProgressBar
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:progress="50"
                    android:max="100"
                    android:progressDrawable="@drawable/bg_progress_bar_red_flat" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="1 of 2 spots filled"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Price/Tags Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_standard"
                app:cardBackgroundColor="@color/brand_error_bg_alt">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COMMUNITY"
                            android:textColor="@color/brand_error_solid"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Volunteer"
                            android:textColor="@color/brand_error_solid"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:gravity="end"
                        android:orientation="vertical">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_pill_pink_transparent"
                                android:text="UPI"
                                android:textColor="@color/brand_error_solid"
                                android:textSize="9sp"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:layout_marginEnd="6dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_pill_pink_transparent"
                                android:text="Cash"
                                android:textColor="@color/brand_error_solid"
                                android:textSize="9sp"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_pill_pink_transparent"
                            android:text="In Person"
                            android:textColor="@color/brand_error_solid"
                            android:textSize="9sp"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp" />
                    </LinearLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Main Content Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Emergency food support"
                    android:textColor="@color/text_header"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Need help distributing meal kits to elderly neighbors who are living alone. We have 10 kits ready but only 1 person available today."
                    android:textColor="@color/text_subheadline"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp" />

                <!-- Meta Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill_pink_transparent"
                        android:text="● Food"
                        android:textColor="@color/brand_error_solid"
                        android:textSize="12sp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="10m ago"
                        android:textColor="@color/text_subheadline"
                        android:textSize="12sp"
                        app:drawableStartCompat="@drawable/ic_bell"
                        app:drawableTint="@color/text_subheadline"
                        android:drawablePadding="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="2 responses"
                        android:textColor="@color/text_subheadline"
                        android:textSize="12sp"
                        app:drawableStartCompat="@drawable/ic_messages_active"
                        app:drawableTint="@color/text_subheadline"
                        android:drawablePadding="6dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="0.8 km"
                    android:textColor="@color/text_subheadline"
                    android:textSize="12sp"
                    app:drawableStartCompat="@drawable/ic_nav_map"
                    app:drawableTint="@color/text_subheadline"
                    android:drawablePadding="6dp" />

                <!-- Audio Block -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface_background_clean">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/bg_circle_blue_solid"
                            android:padding="8dp" />

                        <!-- Waves Placeholder -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <View android:layout_width="3dp" android:layout_height="12dp" android:background="@color/brand_primary_light" android:layout_marginEnd="3dp"/>
                            <View android:layout_width="3dp" android:layout_height="20dp" android:background="@color/brand_primary_light" android:layout_marginEnd="3dp"/>
                            <View android:layout_width="3dp" android:layout_height="16dp" android:background="@color/brand_primary" android:layout_marginEnd="3dp"/>
                            <View android:layout_width="3dp" android:layout_height="24dp" android:background="@color/brand_primary" android:layout_marginEnd="3dp"/>
                            <View android:layout_width="3dp" android:layout_height="14dp" android:background="@color/brand_primary" android:layout_marginEnd="3dp"/>
                            <View android:layout_width="3dp" android:layout_height="18dp" android:background="@color/brand_primary_light" android:layout_marginEnd="3dp"/>
                            <View android:layout_width="3dp" android:layout_height="12dp" android:background="@color/brand_primary_light" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0:22"
                            android:textColor="@color/text_subheadline"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Map View Placeholder -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_standard">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_map_vector" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Profile Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_standard">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:id="@+id/ivUser"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:src="@drawable/bg_image_placeholder"
                                android:background="@drawable/bg_circle_grey_solid" />
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/ivUser"
                                android:layout_marginStart="16dp"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ramesh Kumar"
                                    android:textColor="@color/text_header"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="★ 4.8  •  12 tasks completed"
                                    android:textColor="@color/text_subheadline"
                                    android:textSize="12sp" />
                            </LinearLayout>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:background="@drawable/bg_pill_pink_transparent"
                                android:text="ID Verified"
                                android:textColor="@color/brand_error_solid"
                                android:textSize="10sp"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp" />
                        </RelativeLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Member since Jan 2024"
                                android:textColor="@color/text_muted"
                                android:textSize="11sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="See 12 reviews →"
                                android:textColor="@color/brand_primary"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:orientation="horizontal">
                            <com.google.android.material.button.MaterialButton
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="8dp"
                                android:text="Call"
                                android:textColor="@color/brand_primary"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                app:strokeColor="@color/brand_primary"
                                app:cornerRadius="24dp"
                                app:icon="@drawable/ic_call_outline"
                                app:iconTint="@color/brand_primary" />
                            <com.google.android.material.button.MaterialButton
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:layout_marginStart="8dp"
                                android:text="SMS"
                                android:textColor="@color/brand_primary"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                app:strokeColor="@color/brand_primary"
                                app:cornerRadius="24dp"
                                app:icon="@drawable/ic_chat_outline"
                                app:iconTint="@color/brand_primary" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky Bottom Button -->
    <LinearLayout
        android:id="@+id/bottomCta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVolunteerSticky"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="I'll Volunteer"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/brand_error_solid"
            app:cornerRadius="24dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
