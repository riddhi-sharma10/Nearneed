<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background_clean"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- App Bar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back_arrow" />

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="POST DETAIL"
                    android:textColor="@color/text_header"
                    android:textSize="14sp"
                    android:letterSpacing="0.1" />

                <ImageButton
                    android:id="@+id/btnOptions"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_dropdown_small" 
                    android:rotation="270"
                    app:tint="@color/text_header"/>
            </RelativeLayout>

            <!-- Hero Image Block (Pink Area) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/brand_error_bg_alt"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="32dp"
                android:paddingBottom="32dp">

                <!-- Placeholder for Basket Image -->
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_circle_grey_solid"
                    android:src="@drawable/ic_check_solid_white"
                    app:tint="@color/brand_error_solid" />

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Food Support"
                    android:textColor="@color/brand_error_solid"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- URGENT Banner -->
                            <TextView
                                style="@style/AppHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />

            <!-- Content Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Emergency food delivery for senior"
                    android:textColor="@color/text_header"
                    android:textSize="22sp" />

                <!-- Meta Pills Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill_pink_transparent"
                        android:text="Food"
                        android:textColor="@color/brand_error_solid"
                        android:textSize="11sp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="5m ago"
                        android:textColor="@color/text_subheadline"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="2 responses"
                        android:textColor="@color/text_subheadline"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="0.4 km"
                        android:textColor="@color/text_subheadline"
                        android:textSize="11sp"
                        app:drawableStartCompat="@drawable/ic_loc_pin_small"
                        app:drawableTint="@color/text_subheadline"
                        android:drawablePadding="4dp" />
                </LinearLayout>

                <TextView
                    style="@style/AppDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Need 4 volunteers to help distribute meal kits to elderly neighbors in block 4 who are unable to leave home due to construction."
                    android:textColor="@color/text_subheadline"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

                <!-- Audio Block -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_card_audio"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="16dp">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_solid_red">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <!-- Dummy audio waves -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="24dp"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <!-- Just simulated vertical bars using views -->
                        <View android:layout_width="2dp" android:layout_height="12dp" android:background="@color/brand_error_accent_light" android:layout_marginEnd="4dp"/>
                        <View android:layout_width="2dp" android:layout_height="18dp" android:background="@color/brand_error_accent" android:layout_marginEnd="4dp"/>
                        <View android:layout_width="2dp" android:layout_height="14dp" android:background="@color/brand_error_accent_light" android:layout_marginEnd="4dp"/>
                        <View android:layout_width="2dp" android:layout_height="24dp" android:background="@color/brand_error_dark" android:layout_marginEnd="4dp"/>
                        <View android:layout_width="2dp" android:layout_height="16dp" android:background="@color/brand_error_accent_light" android:layout_marginEnd="4dp"/>
                        <View android:layout_width="2dp" android:layout_height="20dp" android:background="@color/brand_error" android:layout_marginEnd="4dp"/>
                        <View android:layout_width="2dp" android:layout_height="12dp" android:background="@color/brand_error_accent_light" android:layout_marginEnd="4dp"/>
                        <View android:layout_width="2dp" android:layout_height="8dp"  android:background="@color/brand_error_bg" android:layout_marginEnd="4dp"/>
                        <View android:layout_width="2dp" android:layout_height="4dp"  android:background="@color/brand_error_bg" />
                    </LinearLayout>

                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:14"
                        android:textColor="@color/brand_error_vibrant"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Volunteers Needed Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_card_outline"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        
                        <TextView
                            style="@style/AppHeading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="VOLUNTEERS NEEDED"
                            android:textColor="@color/text_subheadline"
                            android:textSize="10sp"
                            android:letterSpacing="0.05" />

                        <TextView
                            style="@style/AppHeading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_pill_pink_transparent"
                            android:text="2 / 4 Filled"
                            android:textColor="@color/brand_error_solid"
                            android:textSize="10sp" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_circle_solid_red"
                            android:src="@drawable/bg_image_placeholder" />

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_circle_solid_red"
                            android:src="@drawable/bg_image_placeholder" />

                         <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_dashed_circle_grey">
                             <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" android:textColor="@color/text_muted" android:layout_gravity="center" android:textSize="18sp"/>
                         </FrameLayout>

                         <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_dashed_circle_grey">
                             <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" android:textColor="@color/text_muted" android:layout_gravity="center" android:textSize="18sp"/>
                         </FrameLayout>

                    </LinearLayout>
                </LinearLayout>

                <!-- Location Block -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp">
                    
                    <TextView
                        android:id="@+id/c4_location"
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:text="LOCATION"
                        android:textColor="@color/text_subheadline"
                        android:textSize="10sp"
                        android:letterSpacing="0.05" />

                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Koramangala 4th Block"
                        android:textColor="@color/text_header"
                        android:textSize="10sp" />

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_below="@id/c4_location"
                        android:layout_marginTop="24dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_map_vector"
                        android:background="@drawable/bg_card_base"
                        android:clipToOutline="true" />
                </RelativeLayout>

                <!-- Profile Block -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_card_outline"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/ivAvatar"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_circle_grey_solid"
                            android:src="@drawable/bg_image_placeholder" />

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_alignEnd="@id/ivAvatar"
                            android:layout_alignBottom="@id/ivAvatar"
                            android:src="@drawable/ic_check_solid_white"
                            android:background="@drawable/bg_circle_solid_red"
                            app:tint="@color/white"
                            android:padding="2dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/ivAvatar"
                            android:layout_toStartOf="@id/tvScoreContainer"
                            android:layout_marginStart="12dp"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">

                            <TextView
                                style="@style/AppHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Priya Singh"
                                android:textColor="@color/text_header"
                                android:textSize="15sp" />

                            <TextView
                                style="@style/AppDescription"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ID Verified"
                                android:textColor="@color/brand_success"
                                android:textSize="11sp" />

                            <TextView
                                style="@style/AppHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="MEMBER SINCE OCT 2023"
                                android:textColor="@color/text_muted"
                                android:textSize="8sp"
                                android:letterSpacing="0.05" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/tvScoreContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:background="@color/brand_warning_bg"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp">
                            <TextView
                                style="@style/AppHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="★ 4.9 Score"
                                android:textColor="@color/brand_warning_text_alt"
                                android:textSize="10sp" />
                        </LinearLayout>

                    </RelativeLayout>

                    <!-- Profile Actions -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="36dp"
                            android:layout_marginEnd="6dp"
                            style="@style/AppHeading"
                            android:background="@drawable/bg_card_audio"
                            android:gravity="center"
                            android:text="Call"
                            android:textColor="@color/text_header"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="36dp"
                            android:layout_marginStart="6dp"
                            style="@style/AppHeading"
                            android:background="@drawable/bg_card_audio"
                            android:gravity="center"
                            android:text="SMS"
                            android:textColor="@color/text_header"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
            
            <!-- Bottom Inline CTA Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface_background_clean"
                android:orientation="vertical"
                android:paddingTop="32dp"
                android:paddingBottom="48dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVolunteerSticky"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="I'll Volunteer"
                    android:textColor="@color/white"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app:icon="@drawable/ic_forward_arrow"
                    app:iconGravity="textEnd"
                    app:iconTint="@color/white"
                    app:backgroundTint="@color/brand_error_solid"
                    app:cornerRadius="16dp"
                    android:elevation="0dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>









