<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCFAFA"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Close button row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_circle_grey_solid"
                android:src="@drawable/ic_close_grey" />
        </RelativeLayout>

        <!-- Flexbox Wrapper: Centers ALL internal content vertically -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Success icon -->
            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_circle_pink"
                android:layout_gravity="center_horizontal">

                <FrameLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_solid_red">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check_solid_white"
                        android:importantForAccessibility="no" />
                </FrameLayout>
            </FrameLayout>

            <!-- Headline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Your post is live."
                android:textColor="#101D33"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="People within 2 km have been notified."
                android:textColor="#64748B"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_gravity="center_horizontal" />
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="SMS sent to 42 neighbours."
                android:textColor="#F43F5E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_gravity="center_horizontal" />

            <!-- Auto redirect block -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvAutoRedirect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="auto-redirect in 3s"
                    android:textColor="#F43F5E"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <ProgressBar
                    android:id="@+id/pbAutoRedirect"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progress="100"
                    android:max="100"
                    android:progressDrawable="@drawable/bg_progress_bar_red_flat" />
            </LinearLayout>

            <!-- Bottom CTAs (Now centered with the rest of the flow) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackToFeed"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="40dp"
                android:text="Back to Feed"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="#F43F5E"
                app:cornerRadius="16dp"
                android:elevation="0dp" />

            <TextView
                android:id="@+id/btnViewMyPost"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:text="View My Post"
                android:textColor="#F43F5E"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
