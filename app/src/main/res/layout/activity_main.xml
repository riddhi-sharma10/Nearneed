<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="160dp">

            <!-- Top Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">
                
                <ImageView
                    android:id="@+id/ivLogo"
                    android:importantForAccessibility="no"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_logo_home_circle"
                    android:elevation="8dp"
                    android:outlineAmbientShadowColor="#94A3B8" />

                <LinearLayout
                    android:id="@+id/llLocationSelector"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:orientation="vertical"
                    android:gravity="center">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Location"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.05" />
                        
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="4dp">
                        
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_loc_pin_small"
                            app:tint="#F43F5E"
                            android:importantForAccessibility="no" />
                            
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="Downtown, NY"
                            android:textColor="#0F172A"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                            
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_dropdown_small"
                            android:importantForAccessibility="no" />
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivNotifications"
                    android:importantForAccessibility="no"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_bell_dot" />
            </RelativeLayout>

            <!-- Filter Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:clipToPadding="false"
                android:layout_marginTop="24dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cgFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:chipSpacingHorizontal="12dp">

                    <com.google.android.material.chip.Chip
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_all"
                        android:checkable="true"
                        android:checked="true"
                        app:chipBackgroundColor="@color/sel_dash_chip_bg_color"
                        app:chipStrokeColor="@color/sel_dash_chip_stroke"
                        app:chipStrokeWidth="1dp"
                        android:textColor="@color/sel_dash_chip_text"
                        app:checkedIconVisible="false" />

                    <com.google.android.material.chip.Chip
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_gigs"
                        android:checkable="true"
                        app:chipBackgroundColor="@color/sel_dash_chip_bg_color"
                        app:chipStrokeColor="@color/sel_dash_chip_stroke"
                        app:chipStrokeWidth="1dp"
                        android:textColor="@color/sel_dash_chip_text"
                        app:checkedIconVisible="false" />

                    <com.google.android.material.chip.Chip
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_community"
                        android:checkable="true"
                        app:chipBackgroundColor="@color/sel_dash_chip_bg_color"
                        app:chipStrokeColor="@color/sel_dash_chip_stroke"
                        app:chipStrokeWidth="1dp"
                        android:textColor="@color/sel_dash_chip_text"
                        app:checkedIconVisible="false" />

                    <com.google.android.material.chip.Chip
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_near_by"
                        android:checkable="true"
                        app:chipBackgroundColor="@color/sel_dash_chip_bg_color"
                        app:chipStrokeColor="@color/sel_dash_chip_stroke"
                        app:chipStrokeWidth="1dp"
                        android:textColor="@color/sel_dash_chip_text"
                        app:checkedIconVisible="false" />

                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/llFeedContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="24dp"
                android:clipToPadding="false"
                android:clipChildren="false">

                <!-- CARD 1: Plumbing Repair -->
                <FrameLayout
                    android:id="@+id/cardGig1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_card_base"
                    android:elevation="2dp"
                    android:outlineSpotShadowColor="#E2E8F0">
                    
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_left_border_blue" />
                    
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:layout_marginStart="4dp">
                        
                        <TextView
                            android:id="@+id/c1_tag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/card_img_1"
                            android:layout_marginEnd="12dp"
                            android:text="@string/txt_verified"
                            android:textColor="#2563EB"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            app:drawableStartCompat="@drawable/ic_verified_badge"
                            android:drawablePadding="4dp" />

                        <TextView
                            android:id="@+id/c1_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/card_img_1"
                            android:layout_marginEnd="12dp"
                            android:layout_below="@id/c1_tag"
                            android:layout_marginTop="4dp"
                            android:text="@string/txt_plumbing_repair"
                            android:textColor="#0F172A"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/c1_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/card_img_1"
                            android:layout_marginEnd="12dp"
                            android:layout_below="@id/c1_title"
                            android:layout_marginTop="2dp"
                            android:text="@string/txt_price_400"
                            android:textColor="#1D5EF3"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/c1_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/card_img_1"
                            android:layout_marginEnd="12dp"
                            android:layout_below="@id/c1_price"
                            android:layout_marginTop="4dp"
                            android:text="Bathroom pipe burst, need experienced plumber ASAP."
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            android:maxLines="2"
                            android:ellipsize="end" />

                        <LinearLayout
                            android:id="@+id/c1_meta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_below="@id/c1_desc"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="11dp"
                                android:layout_height="11dp"
                                android:src="@drawable/ic_loc_pin_small"
                                app:tint="#94A3B8"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="3dp"
                                android:text="0.3 km  ·  2 min ago"
                                android:textColor="#94A3B8"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_below="@id/c1_meta"
                            android:layout_marginTop="12dp"
                            android:text="@string/txt_view_gig"
                            android:textColor="#2563EB"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:background="@drawable/bg_btn_light_blue"
                            android:gravity="center" />

                        <ImageView
                            android:id="@+id/card_img_1"
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_image_placeholder"
                            android:scaleType="centerCrop"
                            android:importantForAccessibility="no" />

                    </RelativeLayout>
                </FrameLayout>
                
                <!-- CARD 2: Garden Clean-up (Urgent) -->
                <FrameLayout
                    android:id="@+id/cardCommunity1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_card_base"
                    android:elevation="2dp"
                    android:outlineSpotShadowColor="#E2E8F0">
                    
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_left_border_red" />
                    
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:layout_marginStart="4dp">
                        
                        <TextView
                            android:id="@+id/c2_tag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/card_img_2"
                            android:layout_marginEnd="12dp"
                            android:text="@string/txt_urgent"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:background="@drawable/bg_tag_urgent"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp" />

                        <TextView
                            android:id="@+id/c2_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/card_img_2"
                            android:layout_marginEnd="12dp"
                            android:layout_below="@id/c2_tag"
                            android:layout_marginTop="4dp"
                            android:text="@string/txt_garden_cleanup"
                            android:textColor="#0F172A"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/c2_sub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/card_img_2"
                            android:layout_marginEnd="12dp"
                            android:layout_below="@id/c2_title"
                            android:layout_marginTop="2dp"
                            android:text="@string/txt_community_project"
                            android:textColor="#64748B"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/c2_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/card_img_2"
                            android:layout_marginEnd="12dp"
                            android:layout_below="@id/c2_sub"
                            android:layout_marginTop="4dp"
                            android:text="Weekend cleanup drive at the community park. All welcome!"
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            android:maxLines="2"
                            android:ellipsize="end" />

                        <!-- Progress Section -->
                        <RelativeLayout
                            android:id="@+id/c2_progress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toStartOf="@+id/card_img_2"
                            android:layout_below="@id/c2_desc"
                            android:layout_marginTop="10dp"
                            android:layout_marginEnd="12dp">

                            <ProgressBar
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:max="10"
                                android:progress="7"
                                android:progressTint="#F43F5E"
                                android:progressBackgroundTint="#E2E8F0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="@string/txt_7_10_volunteers"
                                android:textColor="#475569"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:layout_alignParentEnd="true"
                                android:text="@string/txt_70_percent"
                                android:textColor="#475569"
                                android:textSize="12sp" />
                        </RelativeLayout>

                        <LinearLayout
                            android:id="@+id/c2_meta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_below="@id/c2_progress"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="11dp"
                                android:layout_height="11dp"
                                android:src="@drawable/ic_loc_pin_small"
                                app:tint="#94A3B8"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="3dp"
                                android:text="1.1 km  ·  15 min ago"
                                android:textColor="#94A3B8"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/btnVolC1"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_below="@id/c2_meta"
                            android:layout_marginTop="12dp"
                            android:text="@string/txt_volunteer"
                            android:textColor="#F43F5E"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:background="@drawable/bg_btn_light_red"
                            android:gravity="center" />

                        <ImageView
                            android:id="@+id/card_img_2"
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_image_placeholder"
                            android:scaleType="centerCrop"
                            android:importantForAccessibility="no" />
                    </RelativeLayout>
                </FrameLayout>

                <!-- CARD 2.5: Emergency Food Delivery (Urgent) -->
                <FrameLayout
                    android:id="@+id/cardCommunity2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_card_base"
                    android:elevation="2dp"
                    android:outlineSpotShadowColor="#E2E8F0">
                    
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_left_border_red" />
                    
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:layout_marginStart="4dp">
                        
                        <TextView
                            android:id="@+id/c4_tag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/card_img_4"
                            android:layout_marginEnd="12dp"
                            android:text="@string/txt_urgent"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:background="@drawable/bg_tag_urgent"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp" />

                        <TextView
                            android:id="@+id/c4_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/card_img_4"
                            android:layout_marginEnd="12dp"
                            android:layout_below="@id/c4_tag"
                            android:layout_marginTop="4dp"
                            android:text="Emergency food delivery for senior"
                            android:textColor="#0F172A"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/c4_sub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/card_img_4"
                            android:layout_marginEnd="12dp"
                            android:layout_below="@id/c4_title"
                            android:layout_marginTop="2dp"
                            android:text="Food Support"
                            android:textColor="#64748B"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/c4_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/card_img_4"
                            android:layout_marginEnd="12dp"
                            android:layout_below="@id/c4_sub"
                            android:layout_marginTop="4dp"
                            android:text="Need 4 volunteers to help distribute meal kits to elderly neighbors in block 4 who are unable to leave home due to construction."
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            android:maxLines="3"
                            android:ellipsize="end" />

                        <!-- Progress Section -->
                        <RelativeLayout
                            android:id="@+id/c4_progress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toStartOf="@+id/card_img_4"
                            android:layout_below="@id/c4_desc"
                            android:layout_marginTop="10dp"
                            android:layout_marginEnd="12dp">

                            <ProgressBar
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:max="4"
                                android:progress="2"
                                android:progressTint="#F43F5E"
                                android:progressBackgroundTint="#E2E8F0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="2/4 Volunteers"
                                android:textColor="#475569"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:layout_alignParentEnd="true"
                                android:text="50%"
                                android:textColor="#475569"
                                android:textSize="12sp" />
                        </RelativeLayout>

                        <LinearLayout
                            android:id="@+id/c4_meta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_below="@id/c4_progress"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="11dp"
                                android:layout_height="11dp"
                                android:src="@drawable/ic_loc_pin_small"
                                app:tint="#94A3B8"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="3dp"
                                android:text="0.4 km  ·  5 min ago"
                                android:textColor="#94A3B8"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/btnVolC2"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_below="@id/c4_meta"
                            android:layout_marginTop="12dp"
                            android:text="@string/txt_volunteer"
                            android:textColor="#F43F5E"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:background="@drawable/bg_btn_light_red"
                            android:gravity="center" />

                        <ImageView
                            android:id="@+id/card_img_4"
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_image_placeholder"
                            android:scaleType="centerCrop"
                            android:importantForAccessibility="no" />
                    </RelativeLayout>
                </FrameLayout>
                
                <!-- CARD 3: Groceries Delivery -->
                <FrameLayout
                    android:id="@+id/cardGig2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:background="@drawable/bg_card_base"
                    android:elevation="2dp"
                    android:outlineSpotShadowColor="#E2E8F0">
                    
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_left_border_blue" />
                    
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:layout_marginStart="4dp">
                        
                        <TextView
                            android:id="@+id/c3_tag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/card_img_3"
                            android:layout_marginEnd="12dp"
                            android:text="@string/txt_verified"
                            android:textColor="#2563EB"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            app:drawableStartCompat="@drawable/ic_verified_badge"
                            android:drawablePadding="4dp" />

                        <TextView
                            android:id="@+id/c3_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/card_img_3"
                            android:layout_marginEnd="12dp"
                            android:layout_below="@id/c3_tag"
                            android:layout_marginTop="4dp"
                            android:text="@string/txt_groceries_delivery"
                            android:textColor="#0F172A"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/c3_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/card_img_3"
                            android:layout_marginEnd="12dp"
                            android:layout_below="@id/c3_title"
                            android:layout_marginTop="2dp"
                            android:text="@string/txt_price_100"
                            android:textColor="#1D5EF3"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/c3_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/card_img_3"
                            android:layout_marginEnd="12dp"
                            android:layout_below="@id/c3_price"
                            android:layout_marginTop="4dp"
                            android:text="Need someone to pick up groceries from D-Mart, Sector 14."
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            android:maxLines="2"
                            android:ellipsize="end" />

                        <LinearLayout
                            android:id="@+id/c3_meta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_below="@id/c3_desc"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="11dp"
                                android:layout_height="11dp"
                                android:src="@drawable/ic_loc_pin_small"
                                app:tint="#94A3B8"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="3dp"
                                android:text="0.7 km  ·  8 min ago"
                                android:textColor="#94A3B8"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_below="@id/c3_meta"
                            android:layout_marginTop="12dp"
                            android:contentDescription="TODO"
                            android:text="@string/txt_view_gig"
                            android:textColor="#2563EB"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:background="@drawable/bg_btn_light_blue"
                            android:gravity="center" />

                        <ImageView
                            android:id="@+id/card_img_3"
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_image_placeholder"
                            android:scaleType="centerCrop"
                            android:importantForAccessibility="no" />

                    </RelativeLayout>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom App Navigation System -->
    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bottomAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:fabAlignmentMode="center"
        app:fabCradleMargin="8dp"
        app:fabCradleRoundedCornerRadius="16dp"
        app:hideOnScroll="false"
        app:backgroundTint="#EBFFFFFF">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            style="@style/Widget.MaterialComponents.BottomNavigationView"
            android:id="@+id/bottomNavView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:menu="@menu/bottom_nav_menu"
            app:itemIconTint="@color/sel_bottom_nav_color"
            app:itemTextColor="@color/sel_bottom_nav_color"
            app:itemRippleColor="#E0F2FE"
            app:labelVisibilityMode="labeled" />
    </com.google.android.material.bottomappbar.BottomAppBar>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:importantForAccessibility="no"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:backgroundTint="#2563EB"
        app:tint="#FFFFFF"
        app:srcCompat="@drawable/ic_plus_white"
        app:cornerRadius="28dp"
        app:layout_anchor="@id/bottomAppBar"
        android:layout_marginBottom="16dp"
        android:outlineAmbientShadowColor="#2563EB"
        android:outlineSpotShadowColor="#2563EB"
        android:elevation="8dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>