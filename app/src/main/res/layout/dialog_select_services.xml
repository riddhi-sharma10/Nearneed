<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_modal"
    android:orientation="vertical"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_drag_handle" />

    <TextView
        style="@style/AppHeading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose Services"
        android:textColor="@color/text_header"
        android:textSize="20sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Select the services you want to add to your profile."
        android:textColor="@color/text_subheadline"
        android:textSize="14sp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/cgAllServices"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:chipSpacingVertical="8dp">
        
        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="48dp" android:text="House Help" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Plumbing" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Electrical" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Cleaning" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Cooking" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Tech Support" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Car Wash" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Personal Training" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Event Help" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Gardening" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Pet Sitting" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Photography" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Tutor" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Elderly Care" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Babysitting" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
        <com.google.android.material.chip.Chip android:id="@+id/chipOthers" style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="48dp" android:text="+ Others" app:chipBackgroundColor="@color/sel_chip_bg_blue" app:chipStrokeColor="@color/sel_chip_stroke_blue" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_blue"/>
    </com.google.android.material.chip.ChipGroup>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilOtherService"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:hintEnabled="false"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etOtherService"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="What else can you provide?"
            android:inputType="text"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddSelected"
        style="@style/AppHeading"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="Add Selected Services"
        android:textColor="@color/white"
        android:textAllCaps="false"
        app:backgroundTint="@color/brand_primary"
        app:cornerRadius="16dp"
        android:elevation="0dp" />

</LinearLayout>
