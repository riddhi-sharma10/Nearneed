<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- ── ENRICHED BACKGROUND ICON PATTERN (Light Greyish Hue) ── -->
    <!-- Scattered icons to create an editorial texture -->

    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="60dp"
        android:layout_marginStart="40dp"
        android:alpha="0.30"
        android:rotation="-15"
        android:src="@drawable/ic_cleaning"
        app:tint="@color/icon_decorative_tint" />

    <ImageView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="160dp"
        android:layout_marginStart="100dp"
        android:alpha="0.25"
        android:rotation="45"
        android:src="@drawable/ic_briefcase_blue"
        app:tint="@color/icon_decorative_tint" />

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="60dp"
        android:alpha="0.35"
        android:rotation="20"
        android:src="@drawable/ic_plumber"
        app:tint="@color/icon_decorative_tint" />

    <ImageView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="200dp"
        android:layout_marginEnd="120dp"
        android:alpha="0.20"
        android:rotation="-30"
        android:src="@drawable/ic_car_blue"
        app:tint="@color/icon_decorative_tint" />

    <!-- Additional Random Icons -->
    <ImageView
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="320dp"
        android:layout_marginEnd="80dp"
        android:alpha="0.28"
        android:rotation="15"
        android:src="@drawable/ic_shield_check"
        app:tint="@color/icon_decorative_tint" />

    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_centerVertical="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="-10dp"
        android:alpha="0.15"
        android:rotation="10"
        android:src="@drawable/ic_groceries"
        app:tint="@color/icon_decorative_tint" />

    <ImageView
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_centerVertical="true"
        android:layout_marginStart="30dp"
        android:alpha="0.30"
        android:rotation="-25"
        android:src="@drawable/ic_gardening"
        app:tint="@color/icon_decorative_tint" />

    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_centerVertical="true"
        android:layout_marginStart="140dp"
        android:alpha="0.25"
        android:rotation="10"
        android:src="@drawable/ic_laptop_blue"
        app:tint="@color/icon_decorative_tint" />

    <ImageView
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="30dp"
        android:alpha="0.45"
        android:rotation="15"
        android:src="@drawable/ic_electrician"
        app:tint="@color/icon_decorative_tint" />

    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="120dp"
        android:layout_marginStart="80dp"
        android:alpha="0.30"
        android:rotation="-10"
        android:src="@drawable/ic_petcare"
        app:tint="@color/icon_decorative_tint" />

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="160dp"
        android:layout_marginEnd="90dp"
        android:alpha="0.25"
        android:rotation="40"
        android:src="@drawable/ic_broom_blue"
        app:tint="@color/icon_decorative_tint" />

    <ImageView
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="130dp"
        android:layout_marginStart="-120dp"
        android:alpha="0.3"
        android:rotation="-50"
        android:src="@drawable/ic_map_dot"
        app:tint="@color/icon_decorative_tint" />

    <ImageView
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="40dp"
        android:layout_marginBottom="60dp"
        android:alpha="0.20"
        android:rotation="15"
        android:src="@drawable/ic_logo"
        app:tint="@color/icon_decorative_tint" />

    <!-- ── CENTER CONTENT ── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Logo Icon (Inner center as seen in image) -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_circle_light_blue"
            android:elevation="0dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_logo"
                app:tint="@color/brand_primary" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="NearNeed"
            android:textColor="@color/text_header"
            android:textSize="28sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Your neighborhood, connected"
            android:textColor="@color/text_subheadline"
            android:textSize="14sp" />

        <!-- ── LOADING ELEMENTS ── -->
        <ProgressBar
            android:id="@+id/loadingProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="240dp"
            android:layout_height="6dp"
            android:layout_marginTop="60dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/bg_progress_bar_blue_flat" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Connecting to your area..."
            android:textColor="@color/text_muted"
            android:textSize="13sp" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="40dp"
        android:text="• • •"
        android:textColor="@color/pagers_indicator_inactive"
        android:textSize="20sp"
        android:letterSpacing="0.2" />

</RelativeLayout>









