<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- ── ENRICHED BACKGROUND ICON PATTERN (Light Greyish Hue) ── -->
    <!-- Scattered icons to create an editorial texture -->

    <ImageView
        android:layout_width="44dp" android:layout_height="44dp"
        android:layout_marginTop="40dp" android:layout_marginStart="30dp"
        android:alpha="0.18" android:rotation="-15"
        android:src="@drawable/ic_solid_broom"
        app:tint="@color/decorative_tint_faint_blue" />

    <ImageView
        android:layout_width="32dp" android:layout_height="32dp"
        android:layout_marginTop="140dp" android:layout_marginStart="90dp"
        android:alpha="0.15" android:rotation="45"
        android:src="@drawable/ic_solid_laptop"
        app:tint="@color/decorative_tint_faint_blue" />

    <ImageView
        android:layout_width="38dp" android:layout_height="38dp"
        android:layout_alignParentEnd="true" android:layout_marginTop="60dp" android:layout_marginEnd="40dp"
        android:alpha="0.20" android:rotation="20"
        android:src="@drawable/ic_solid_wrench"
        app:tint="@color/decorative_tint_faint_blue" />

    <ImageView
        android:layout_width="30dp" android:layout_height="30dp"
        android:layout_alignParentEnd="true" android:layout_marginTop="180dp" android:layout_marginEnd="110dp"
        android:alpha="0.12" android:rotation="-30"
        android:src="@drawable/ic_solid_car"
        app:tint="@color/decorative_tint_faint_blue" />

    <ImageView
        android:layout_width="32dp" android:layout_height="32dp"
        android:layout_marginTop="280dp" android:layout_marginStart="20dp"
        android:alpha="0.15" android:rotation="10"
        android:src="@drawable/ic_solid_medical"
        app:tint="@color/decorative_tint_faint_blue" />

    <ImageView
        android:layout_width="36dp" android:layout_height="36dp"
        android:layout_alignParentEnd="true" android:layout_marginTop="300dp" android:layout_marginEnd="20dp"
        android:alpha="0.18" android:rotation="-10"
        android:src="@drawable/ic_solid_sms"
        app:tint="@color/decorative_tint_faint_blue" />

    <ImageView
        android:layout_width="40dp" android:layout_height="40dp"
        android:layout_centerVertical="true" android:layout_marginStart="-10dp"
        android:alpha="0.15" android:rotation="25"
        android:src="@drawable/ic_solid_plant"
        app:tint="@color/decorative_tint_faint_blue" />

    <ImageView
        android:layout_width="34dp" android:layout_height="34dp"
        android:layout_centerVertical="true" android:layout_alignParentEnd="true" android:layout_marginEnd="60dp"
        android:alpha="0.15" android:rotation="-20"
        android:src="@drawable/ic_solid_supplies"
        app:tint="@color/decorative_tint_faint_blue" />

    <ImageView
        android:layout_width="50dp" android:layout_height="50dp"
        android:layout_centerVertical="true" android:layout_marginStart="140dp"
        android:alpha="0.12" android:rotation="15"
        android:src="@drawable/ic_solid_truck"
        app:tint="@color/decorative_tint_faint_blue" />

    <ImageView
        android:layout_width="42dp" android:layout_height="42dp"
        android:layout_alignParentBottom="true" android:layout_marginBottom="160dp" android:layout_marginStart="40dp"
        android:alpha="0.18" android:rotation="-10"
        android:src="@drawable/ic_solid_oven"
        app:tint="@color/decorative_tint_faint_blue" />

    <ImageView
        android:layout_width="36dp" android:layout_height="36dp"
        android:layout_alignParentBottom="true" android:layout_marginBottom="240dp" android:layout_alignParentEnd="true" android:layout_marginEnd="30dp"
        android:alpha="0.15" android:rotation="30"
        android:src="@drawable/ic_solid_plug"
        app:tint="@color/decorative_tint_faint_blue" />

    <ImageView
        android:layout_width="46dp" android:layout_height="46dp"
        android:layout_alignParentBottom="true" android:layout_marginBottom="60dp" android:layout_marginStart="80dp"
        android:alpha="0.15" android:rotation="10"
        android:src="@drawable/ic_solid_paw"
        app:tint="@color/decorative_tint_faint_blue" />

    <ImageView
        android:layout_width="32dp" android:layout_height="32dp"
        android:layout_alignParentBottom="true" android:layout_marginBottom="100dp" android:layout_alignParentEnd="true" android:layout_marginEnd="80dp"
        android:alpha="0.12" android:rotation="-40"
        android:src="@drawable/ic_solid_firstaid"
        app:tint="@color/decorative_tint_faint_blue" />

    <ImageView
        android:layout_width="38dp" android:layout_height="38dp"
        android:layout_alignParentBottom="true" android:layout_marginBottom="30dp" android:layout_alignParentEnd="true" android:layout_marginEnd="20dp"
        android:alpha="0.15" android:rotation="15"
        android:src="@drawable/ic_solid_wrench"
        app:tint="@color/decorative_tint_faint_blue" />

    <!-- ── CENTER CONTENT ── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/pulseContainer"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_centerInParent="true">

            <!-- Ripple Waves (Scaling Outwards) -->
            <View
                android:id="@+id/ripple1"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_ripple"
                android:alpha="0" />

            <View
                android:id="@+id/ripple2"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_ripple"
                android:alpha="0" />

            <!-- Static Outer Circle (Subtle glow, slightly larger than inner) -->
            <View
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_ripple"
                android:alpha="0.4" />

            <!-- Solid Inner Circle (The Logo itself) -->
            <ImageView
                android:id="@+id/ivLoadingLogo"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_logo" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="NearNeed"
            android:textColor="@color/text_header"
            android:textSize="28sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Your neighborhood, connected"
            android:textColor="@color/text_subheadline"
            android:textSize="14sp" />

        <!-- ── LOADING ELEMENTS ── -->
        <ProgressBar
            android:id="@+id/loadingProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="240dp"
            android:layout_height="6dp"
            android:layout_marginTop="60dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/bg_progress_bar_blue_flat" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Connecting to your area..."
            android:textColor="@color/text_muted"
            android:textSize="13sp" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="40dp"
        android:text="• • •"
        android:textColor="@color/pagers_indicator_inactive"
        android:textSize="20sp"
        android:letterSpacing="0.2" />

</RelativeLayout>









