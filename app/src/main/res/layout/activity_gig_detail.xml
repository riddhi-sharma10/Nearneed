<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="120dp"
        android:clipToPadding="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 1. DISTRICT PREMIUM HEADER (STANDARDIZED) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:paddingHorizontal="24dp">
                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_back_arrow"
                    android:padding="8dp"
                    app:tint="#101D33" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_share"
                        app:tint="#101D33" />
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_marginStart="24dp"
                        android:src="@drawable/ic_more_dots"
                        app:tint="#101D33" />
                </LinearLayout>
            </RelativeLayout>

            <!-- 2. IMMERSIVE MEDIA SECTION -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginHorizontal="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:backgroundTint="#F8FAFC">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/bg_image_placeholder"
                    android:scaleType="centerCrop"/>
            </androidx.cardview.widget.CardView>

            <!-- 3. SLOTS AVAILABLE (SOPHISTICATED) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="32dp"
                android:paddingTop="40dp"
                android:paddingBottom="24dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AVAILABILITY"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="1 spot remaining"
                        android:textColor="#22C55E"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </RelativeLayout>
                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="16dp"
                    android:progress="50"
                    android:progressDrawable="@drawable/bg_progress_bar_blue_flat" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="1 of 2 neighbors applied ●"
                    android:textColor="#94A3B8"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 4. DISTRICT PAYMENT & DESCRIPTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="32dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_base"
                    android:backgroundTint="#F1F5F9"
                    android:padding="24dp"
                    android:elevation="0dp"
                    android:layout_marginTop="8dp">
                    <TextView
                        android:id="@+id/lblPayment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PAYMENT"
                        android:textColor="#64748B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/lblPayment"
                        android:layout_marginTop="4dp"
                        android:text="₹300"
                        android:textColor="#101D33"
                        android:textSize="32sp"
                        android:fontFamily="sans-serif-black" />
                    
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:orientation="vertical"
                        android:gravity="end">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_verified_blue_shield"
                            android:backgroundTint="#FFFFFF"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="5dp"
                            android:text="UPI"
                            android:textColor="#1D5EF3"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_verified_blue_shield"
                            android:backgroundTint="#FFFFFF"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="5dp"
                            android:text="Cash"
                            android:textColor="#1D5EF3"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:text="GIG"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Plumbing Repair"
                    android:textColor="#101D33"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="The main tap in the kitchen is leaking from the base. Need someone with basic plumbing tools to fix it today."
                    android:textColor="#475569"
                    android:textSize="16sp"
                    android:lineSpacingExtra="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔧 Plumbing"
                        android:textColor="#101D33"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_chip_selected"
                        android:backgroundTint="#F1F5F9"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="🕒 10m ago"
                        android:textColor="#101D33"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_chip_selected"
                        android:backgroundTint="#F1F5F9"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp" />
                </LinearLayout>

                <!-- 5. AUDIO WAVEFORM (DISTRICT STYLE) -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginTop="40dp"
                    android:background="@drawable/bg_card_base"
                    android:backgroundTint="#FFFFFF"
                    android:elevation="6dp"
                    android:outlineSpotShadowColor="#E2E8F0"
                    android:paddingHorizontal="16dp">
                    <ImageView
                        android:id="@+id/btnPlayAudio"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_mic_blue"
                        android:background="@drawable/bg_btn_solid_blue"
                        android:padding="12dp"
                        app:tint="#FFFFFF" />
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/btnPlayAudio"
                        android:layout_marginStart="20dp"
                        android:src="@drawable/bg_drag_handle"
                        android:alpha="0.2"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="0:22"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- 6. MAP OVERVIEW -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="40dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/bg_map_vector"
                        android:scaleType="centerCrop"
                        android:alpha="0.4"/>
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_loc_pin_small"
                        app:tint="#1D5EF3" />
                </androidx.cardview.widget.CardView>

                <!-- 7. AUTHOR PROFILE SECTION -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="48dp"
                    android:layout_marginBottom="48dp"
                    android:orientation="vertical">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:id="@+id/ivAuthorAvatar"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/bg_image_placeholder"
                            android:background="@drawable/bg_circle_light_blue"
                            android:padding="3dp"
                            android:scaleType="centerCrop"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/ivAuthorAvatar"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ramesh Kumar"
                                android:textColor="#101D33"
                                android:textSize="19sp"
                                android:fontFamily="sans-serif-black" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="VERIFIED NEIGHBOR ● 4.8 ★"
                                android:textColor="#22C55E"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08"/>
                        </LinearLayout>
                    </RelativeLayout>
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="56dp"
                            android:text="Call Neighbor"
                            android:textColor="#1D5EF3"
                            android:textAllCaps="false"
                            app:backgroundTint="#FFFFFF"
                            app:strokeColor="#1D5EF3"
                            app:strokeWidth="1dp"
                            app:cornerRadius="16dp" />
                        <com.google.android.material.button.MaterialButton
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="56dp"
                            android:layout_marginStart="12dp"
                            android:text="Send Message"
                            android:textColor="#1D5EF3"
                            android:textAllCaps="false"
                            app:backgroundTint="#FFFFFF"
                            app:strokeColor="#1D5EF3"
                            app:strokeWidth="1dp"
                            app:cornerRadius="16dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- DUMMY SCROLL BUFFER (DOUBLE PROTECTION) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="180dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FLOATING APPLY ACTION -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="24dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="24dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApply"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Apply for this Gig"
            android:textAllCaps="false"
            android:textSize="17sp"
            android:textStyle="bold"
            app:cornerRadius="24dp"
            app:backgroundTint="#2563EB"
            app:insetTop="0dp"
            app:insetBottom="0dp" />
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
