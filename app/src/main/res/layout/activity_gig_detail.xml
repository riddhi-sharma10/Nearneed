<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:paddingHorizontal="24dp">
                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_back_arrow"
                    app:tint="#101D33" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Details"
                    android:textColor="#101D33"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_share"
                        app:tint="#101D33" />
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="20dp"
                        android:src="@drawable/ic_more_dots"
                        app:tint="#101D33" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Hero Image -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:src="@drawable/bg_image_placeholder"
                android:scaleType="centerCrop"/>

            <!-- Slots Info Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SLOTS AVAILABLE"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="1 spot remaining"
                        android:textColor="#1D5EF3"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </RelativeLayout>
                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:progress="50"
                    android:progressDrawable="@drawable/bg_progress_bar_blue_flat" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="1 of 2 neighbors applied"
                    android:textColor="#94A3B8"
                    android:textSize="11sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" android:layout_marginHorizontal="24dp" />

            <!-- Payment Card -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">
                <TextView
                    android:id="@+id/lblPayment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAYMENT"
                    android:textColor="#1D5EF3"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvGigPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/lblPayment"
                    android:layout_marginTop="4dp"
                    android:text="₹300"
                    android:textColor="#101D33"
                    android:textSize="32sp"
                    android:fontFamily="sans-serif-black" />
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:orientation="vertical"
                    android:gravity="end">
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_card_base"
                            android:backgroundTint="#F1F5F9"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="UPI"
                            android:textColor="#1D5EF3"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_card_base"
                            android:backgroundTint="#F1F5F9"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="Cash"
                            android:textColor="#1D5EF3"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_card_base"
                        android:backgroundTint="#F1F5F9"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="In Person"
                        android:textColor="#1D5EF3"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Text Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">
                <TextView
                    android:id="@+id/tvGigTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Plumbing Repair"
                    android:textColor="#101D33"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-black" />
                <TextView
                    android:id="@+id/tvGigDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="The main tap in the kitchen is leaking from the base. Need someone with basic plumbing tools to fix it today."
                    android:textColor="#64748B"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp" />

                <!-- Badges Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔧 Plumbing"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:background="@drawable/bg_card_base"
                        android:backgroundTint="#F1F5F9"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="🕒 10m ago"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:background="@drawable/bg_card_base"
                        android:backgroundTint="#F1F5F9"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="📄 2 responses"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:background="@drawable/bg_card_base"
                        android:backgroundTint="#F1F5F9"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp" />
                </LinearLayout>
                
                <TextView
                    android:id="@+id/tvGigDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="📍 0.8 km"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:layout_marginBottom="24dp" />

                <!-- Audio Waveform Section -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="16dp">
                    <ImageView
                        android:id="@+id/btnPlayAudio"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_mic_blue"
                        android:background="@drawable/bg_btn_solid_blue"
                        android:padding="10dp"
                        app:tint="#FFFFFF" />
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/btnPlayAudio"
                        android:layout_marginStart="16dp"
                        android:src="@drawable/bg_drag_handle"
                        android:alpha="0.2"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="0:22"
                        android:textColor="#94A3B8"
                        android:textSize="11sp" />
                </RelativeLayout>

                <!-- Map View -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/bg_map_vector"
                        android:scaleType="centerCrop"
                        android:alpha="0.8"/>
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_loc_pin_small"
                        app:tint="#1D5EF3" />
                </androidx.cardview.widget.CardView>

                <!-- Author Details -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_card_outline"
                    android:padding="20dp"
                    android:orientation="vertical">
                    
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:id="@+id/ivAvatar"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/bg_image_placeholder"
                            android:background="@drawable/bg_circle_light_blue"
                            android:padding="2dp"
                            android:scaleType="centerCrop"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/ivAvatar"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ramesh Kumar"
                                    android:textColor="#101D33"
                                    android:textSize="16sp"
                                    android:fontFamily="sans-serif-black" />
                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:layout_marginStart="6dp"
                                    android:src="@drawable/ic_verified_badge"
                                    app:tint="#1D5EF3" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    android:text="Verified"
                                    android:textColor="#1D5EF3"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="⭐ 4.6 ● 12 tasks completed"
                                android:textColor="#64748B"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </RelativeLayout>
                    
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Member since Jan 2024"
                            android:textColor="#94A3B8"
                            android:textSize="11sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="See 12 reviews →"
                            android:textColor="#1D5EF3"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_card_outline"
                            android:gravity="center"
                            android:text="📞 Call"
                            android:textColor="#1D5EF3"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="44dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_card_outline"
                            android:gravity="center"
                            android:text="✉ SMS"
                            android:textColor="#1D5EF3"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
            
            <!-- Bottom Action Button -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp"
                android:layout_marginBottom="24dp"
                android:background="@android:color/transparent">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApply"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Apply for this Gig →"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:cornerRadius="28dp"
                    app:backgroundTint="#2563EB" />
            </RelativeLayout>
            
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
