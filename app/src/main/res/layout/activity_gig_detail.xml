<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:ignore="HardcodedText,ContentDescription">

    <!-- App Bar -->
    <RelativeLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back_arrow"
            app:tint="@color/text_header" />

        <TextView
            style="@style/AppHeading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Gig Details"
            android:textColor="@color/text_header"
            android:textSize="18sp" />

        <ImageButton
            android:id="@+id/btnShare"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/btnOptions"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_share"
            app:tint="@color/text_header" />

        <ImageButton
            android:id="@+id/btnOptions"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_dots"
            app:tint="@color/text_header" />

    </RelativeLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="48dp"
            android:clipToPadding="false">

            <!-- Hero Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/ivHeroGig"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bg_image_placeholder"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>


            <!-- Price/Tags Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_standard"
                app:cardBackgroundColor="@color/brand_primary_light">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PAID GIG"
                            android:textColor="@color/brand_primary"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvGigPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹300"
                            android:textColor="@color/brand_primary"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:gravity="end"
                        android:orientation="vertical">
                        
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="@color/white"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/brand_primary_light"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="UPI"
                                android:textColor="@color/brand_primary"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="@color/white"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/brand_primary_light">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cash"
                                android:textColor="@color/brand_primary"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Main Content Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvGigTitle"
                    style="@style/AppHeading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Plumbing Repair"
                    android:textColor="@color/text_header"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/tvGigDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Need help fixing a leaky pipe in the kitchen. Tools provided."
                    android:textColor="@color/text_subheadline"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp" />

                <!-- Meta Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvGigPillCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill_pink_transparent"
                        android:text="● Repair"
                        android:textColor="@color/brand_primary"
                        android:textSize="12sp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="10m ago"
                        android:textColor="@color/text_subheadline"
                        android:textSize="12sp"
                        app:drawableStartCompat="@drawable/ic_bell"
                        app:drawableTint="@color/text_subheadline"
                        android:drawablePadding="6dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvGigDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="0.8 km"
                    android:textColor="@color/text_subheadline"
                    android:textSize="12sp"
                    app:drawableStartCompat="@drawable/ic_nav_map"
                    app:drawableTint="@color/text_subheadline"
                    android:drawablePadding="6dp" />

                <!-- Audio Block -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/brand_primary_light">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_circle_solid_white" />
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_media_play"
                                app:tint="@color/brand_primary" />
                        </FrameLayout>

                        <!-- Waves Placeholder -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <View android:layout_width="3dp" android:layout_height="12dp" android:background="@color/brand_info_accent_soft" android:layout_marginEnd="3dp"/>
                            <View android:layout_width="3dp" android:layout_height="20dp" android:background="@color/brand_info_accent_soft" android:layout_marginEnd="3dp"/>
                            <View android:layout_width="3dp" android:layout_height="16dp" android:background="@color/brand_primary" android:layout_marginEnd="3dp"/>
                            <View android:layout_width="3dp" android:layout_height="24dp" android:background="@color/brand_primary" android:layout_marginEnd="3dp"/>
                            <View android:layout_width="3dp" android:layout_height="14dp" android:background="@color/brand_primary" android:layout_marginEnd="3dp"/>
                            <View android:layout_width="3dp" android:layout_height="18dp" android:background="@color/brand_info_accent_soft" android:layout_marginEnd="3dp"/>
                            <View android:layout_width="3dp" android:layout_height="12dp" android:background="@color/brand_info_accent_soft" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0:15"
                            android:textColor="@color/brand_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Map View Placeholder -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGigMapPreview"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_standard"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_map_vector" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Profile Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_standard">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:id="@+id/ivAuthor"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:src="@drawable/bg_image_placeholder"
                                android:background="@drawable/bg_circle_light_blue" />
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/ivAuthor"
                                android:layout_marginStart="16dp"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tvAuthorName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ramesh Kumar"
                                    android:textColor="@color/text_header"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="★ 4.8  •  12 tasks completed"
                                    android:textColor="@color/text_subheadline"
                                    android:textSize="12sp" />
                            </LinearLayout>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:background="@drawable/bg_pill_pink_transparent"
                                android:text="ID Verified"
                                android:textColor="@color/brand_primary"
                                android:textSize="10sp"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp" />
                        </RelativeLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Member since Jan 2024"
                                android:textColor="@color/text_muted"
                                android:textSize="11sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="See 12 reviews →"
                                android:textColor="@color/brand_primary"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:orientation="horizontal">
                            <com.google.android.material.button.MaterialButton
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="8dp"
                                android:text="Call"
                                android:textColor="@color/brand_primary"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                app:strokeColor="@color/brand_primary"
                                app:cornerRadius="24dp"
                                app:icon="@drawable/ic_call_outline"
                                app:iconTint="@color/brand_primary" />
                            <com.google.android.material.button.MaterialButton
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:layout_marginStart="8dp"
                                android:text="Msg"
                                android:textColor="@color/brand_primary"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                app:strokeColor="@color/brand_primary"
                                app:cornerRadius="24dp"
                                app:icon="@drawable/ic_chat_outline"
                                app:iconTint="@color/brand_primary" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Bottom Action Button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="32dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGigAction"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Apply for this Gig →"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/brand_primary"
                        app:cornerRadius="24dp" />

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>









