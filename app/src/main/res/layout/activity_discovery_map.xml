<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background">

    <!-- 1. IMMERSIVE MAP BACKGROUND -->
    <FrameLayout
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/bg_map_vector"
            android:scaleType="centerCrop"
            android:alpha="0.4"
            android:tint="@color/divider_soft" />

        <!-- 2. IMMERSIVE PINS -->
        <!-- Gig Pin (Avatar + Price) -->
        <LinearLayout
            android:id="@+id/pin_gig_premium"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:layout_marginTop="-140dp"
            android:layout_marginStart="-80dp"
            android:background="@drawable/bg_immersive_pin_gig"
            android:elevation="6dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/bg_image_placeholder"
                android:background="@drawable/bg_circle_light_blue"
                android:padding="1dp"
                android:scaleType="centerCrop" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:text="₹300"
                android:textColor="@color/brand_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Need Pin (Icon + Text) -->
        <LinearLayout
            android:id="@+id/pin_need_premium"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:layout_marginTop="60dp"
            android:layout_marginStart="120dp"
            android:background="@drawable/bg_immersive_pin_need"
            android:elevation="6dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍎 Food"
                android:textColor="@color/brand_error_solid"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Need Pin (Tools) -->
        <LinearLayout
            android:id="@+id/pin_need_tools"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:layout_marginTop="-40dp"
            android:layout_marginStart="140dp"
            android:background="@drawable/bg_immersive_pin_need"
            android:elevation="6dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚒️ Tools"
                android:textColor="@color/brand_error_solid"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- User "YOU" Pin -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_horizontal"
            android:orientation="vertical">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/bg_image_placeholder"
                android:background="@drawable/bg_circle_light_blue"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:elevation="4dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_chip_selected"
                android:paddingHorizontal="8dp"
                android:paddingVertical="1dp"
                android:text="YOU"
                android:textColor="@color/white"
                android:textSize="8sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <!-- 3. TOP SOPHISTICATED HEADER (SEARCHBAR STYLE) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:paddingHorizontal="16dp"
        android:gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_immersive_header"
            android:elevation="8dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">
            
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/bg_image_placeholder"
                android:background="@drawable/bg_circle_light_blue"
                android:padding="1dp"
                android:scaleType="centerCrop" />
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Koramangala - 2 km"
                    android:textColor="@color/text_header"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● LIVE LOCATION"
                    android:textColor="@color/brand_success_vibrant_alt"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search_grey"
                app:tint="@color/text_muted" />
        </LinearLayout>
    </LinearLayout>

    <!-- 4. FLOATING MAP CONTROLS -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|top"
        android:layout_marginTop="120dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        android:gravity="center">
        
        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_plus_white"
            app:tint="@color/text_header"
            android:background="@drawable/bg_circle_white_card"
            android:padding="12dp"
            android:elevation="6dp"/>
        
        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_layers"
            app:tint="@color/text_header"
            android:background="@drawable/bg_circle_white_card"
            android:padding="12dp"
            android:elevation="6dp"/>

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_loc_pin_small"
            app:tint="@color/text_header"
            android:background="@drawable/bg_circle_white_card"
            android:padding="12dp"
            android:elevation="6dp"/>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddFloating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="160dp"
        app:backgroundTint="@color/brand_primary"
        app:srcCompat="@drawable/ic_plus_white"
        app:tint="@color/white"
        app:elevation="8dp"
        app:fabSize="normal" />

    <!-- 5. HAPPENING NEARBY BOTTOM SECTION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="72dp"
        android:background="@drawable/bg_bottom_sheet_modal"
        android:orientation="vertical"
        android:paddingBottom="24dp"
        android:elevation="12dp">
        
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_drag_handle" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="18 active opportunities ●"
                android:textColor="@color/text_header"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="See list"
                android:textColor="@color/brand_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none"
            android:paddingHorizontal="24dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <TextView
                    android:id="@+id/filterGigs"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:paddingHorizontal="20dp"
                    android:gravity="center"
                    android:text="Gigs"
                    android:textColor="@color/text_subheadline"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/filterAll"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_chip_selected"
                    android:paddingHorizontal="20dp"
                    android:gravity="center"
                    android:text="All"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/filterCommunity"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:paddingHorizontal="20dp"
                    android:gravity="center"
                    android:text="Community"
                    android:textColor="@color/text_subheadline"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />

                <FrameLayout
                    android:id="@+id/filterEmergency"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/bg_btn_solid_red"
                    android:elevation="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="!"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </FrameLayout>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- 5. PIN PREVIEW MODAL (Hidden by default) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPinPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:layout_marginBottom="140dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="16dp"
        android:visibility="gone"
        tools:visibility="visible">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/ivUserAvatar"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/bg_image_placeholder"
                    android:background="@drawable/bg_circle_light_blue"
                    android:padding="2dp"
                    android:scaleType="centerCrop"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ivUserAvatar"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rahul S. • VERIFIED"
                        android:textColor="@color/text_header"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.8★ • Neighbour Score • 0.8 km"
                        android:textColor="@color/text_subheadline"
                        android:textSize="11sp" />
                </LinearLayout>
                <ImageView
                    android:id="@+id/btnClosePreview"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/ic_close_grey"
                    android:background="@drawable/bg_circle_grey_solid"
                    android:padding="8dp" />
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_chip_selected"
                android:backgroundTint="@color/brand_primary_light"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="Plumbing"
                android:textColor="@color/brand_primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Plumbing Repair"
                android:textColor="@color/text_header"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <TextView
                    android:id="@+id/tvPricePreview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="₹300"
                    android:textColor="@color/brand_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 / 2 slots filled"
                    android:textColor="@color/text_subheadline"
                    android:textSize="12sp" />
                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="200dp"
                    android:layout_height="6dp"
                    android:layout_below="@+id/tvPricePreview"
                    android:layout_marginTop="-8dp"
                    android:progress="50"
                    android:progressDrawable="@drawable/bg_progress_bar_blue_flat" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">
                
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewFullPostPreview"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="56dp"
                    android:text="View Full Post →"
                    android:textColor="@color/white"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/brand_primary"
                    app:cornerRadius="16dp" />

                <ImageButton
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_mic_blue"
                    app:tint="@color/text_subheadline"
                    android:background="@drawable/bg_card_outline" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 6. STANDARD BOTTOM SYSTEM -->
    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bottomAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:fabAlignmentMode="center"
        app:fabCradleMargin="8dp"
        app:fabCradleRoundedCornerRadius="16dp"
        app:backgroundTint="@color/white">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:menu="@menu/bottom_nav_menu"
            app:itemIconTint="@color/sel_bottom_nav_color"
            app:itemTextColor="@color/sel_bottom_nav_color"
            app:labelVisibilityMode="labeled" />
    </com.google.android.material.bottomappbar.BottomAppBar>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:backgroundTint="@color/brand_primary"
        app:srcCompat="@drawable/ic_plus_white"
        app:cornerRadius="28dp"
        app:layout_anchor="@id/bottomAppBar"
        android:layout_marginBottom="16dp"
        android:elevation="8dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>









