                        <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/bg_image_placeholder" android:background="@drawable/bg_circle_light_blue" android:scaleType="centerCrop"/>
                        <View android:layout_width="12dp" android:layout_height="12dp" android:layout_gravity="bottom|end" android:background="@drawable/bg_dot_green"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_toEndOf="@id/avRachel" android:layout_toStartOf="@+id/trRachel" android:layout_centerVertical="true" android:layout_marginStart="12dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rachel" android:textColor="#0F172A" android:textSize="15sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="I can help with the plumbing! Let me know." android:textColor="#0F172A" android:textSize="13sp" android:textStyle="bold" android:layout_marginTop="3dp" android:maxLines="1" android:ellipsize="end"/>
                    </LinearLayout>
                    <LinearLayout android:id="@+id/trRachel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:orientation="vertical" android:gravity="end">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2 min" android:textColor="#94A3B8" android:textSize="11sp"/>
                        <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_dot_green" android:layout_gravity="end" android:layout_marginTop="5dp" android:backgroundTint="#1D5EF3"/>
                    </LinearLayout>
                </RelativeLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" android:layout_marginStart="78dp"/>

                <!-- 2. Manya Awasthi -->
