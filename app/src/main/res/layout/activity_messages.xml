                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3 hrs" android:textColor="#94A3B8" android:textSize="11sp"/>
                        <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_dot_green" android:layout_gravity="end" android:layout_marginTop="5dp" android:backgroundTint="#1D5EF3"/>
