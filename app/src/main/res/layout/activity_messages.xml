<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="false"
        android:paddingBottom="90dp"
        android:clipToPadding="false"
        android:overScrollMode="always"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Status bar spacer -->
            <View android:layout_width="match_parent" android:layout_height="48dp" android:background="#FFFFFF" />

            <!-- Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:background="#FFFFFF">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Messages"
                    android:textColor="#101D33"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-black"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Search Bar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="10dp"
                android:background="#FFFFFF">
                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:hint="Search messages..."
                    android:textSize="14sp"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8"
                    android:drawableStart="@drawable/ic_search_grey"
                    android:drawablePadding="10dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_search_pill"
                    android:inputType="text"
                    android:singleLine="true"
                    android:imeOptions="actionSearch" />
            </RelativeLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />

            <!-- ===== Conversation List ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF">

