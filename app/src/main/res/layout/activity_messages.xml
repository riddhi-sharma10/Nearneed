                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="We're organizing a cleanup drive this Sunday!" android:textColor="#64748B" android:textSize="13sp" android:layout_marginTop="3dp" android:maxLines="1" android:ellipsize="end"/>
                    </LinearLayout>
                    <TextView android:id="@+id/trSneha" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="Thu" android:textColor="#94A3B8" android:textSize="11sp"/>
                </RelativeLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" android:layout_marginStart="78dp"/>

                <!-- 13. Arjun Kumar -->
                <RelativeLayout android:id="@+id/convArjun" android:layout_width="match_parent" android:layout_height="74dp" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="?attr/selectableItemBackground" android:gravity="center_vertical">
                    <FrameLayout android:id="@+id/avArjun" android:layout_width="50dp" android:layout_height="50dp" android:layout_centerVertical="true">
                        <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/bg_image_placeholder" android:background="@drawable/bg_circle_light_blue" android:scaleType="centerCrop"/>
                        <View android:layout_width="12dp" android:layout_height="12dp" android:layout_gravity="bottom|end" android:background="@drawable/bg_circle_grey_solid"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_toEndOf="@id/avArjun" android:layout_toStartOf="@+id/trArjun" android:layout_centerVertical="true" android:layout_marginStart="12dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Arjun Kumar" android:textColor="#0F172A" android:textSize="15sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="I left the keys under the mat as discussed." android:textColor="#64748B" android:textSize="13sp" android:layout_marginTop="3dp" android:maxLines="1" android:ellipsize="end"/>
                    </LinearLayout>
                    <TextView android:id="@+id/trArjun" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="Wed" android:textColor="#94A3B8" android:textSize="11sp"/>
                </RelativeLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom App Navigation System -->
    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bottomAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:fabAlignmentMode="center"
        app:fabCradleMargin="8dp"
        app:fabCradleRoundedCornerRadius="16dp"
        app:hideOnScroll="false"
        app:backgroundTint="#EBFFFFFF">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            style="@style/Widget.MaterialComponents.BottomNavigationView"
            android:id="@+id/bottomNavView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:menu="@menu/bottom_nav_menu_messages"
            app:itemIconTint="@color/sel_bottom_nav_color"
            app:itemTextColor="@color/sel_bottom_nav_color"
            app:itemRippleColor="#E0F2FE"
            app:labelVisibilityMode="labeled" />
    </com.google.android.material.bottomappbar.BottomAppBar>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:importantForAccessibility="no"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:backgroundTint="#2563EB"
        app:tint="#FFFFFF"
        app:srcCompat="@drawable/ic_plus_white"
        app:cornerRadius="28dp"
        app:layout_anchor="@id/bottomAppBar"
        android:layout_marginBottom="16dp"
        android:outlineAmbientShadowColor="#2563EB"
        android:outlineSpotShadowColor="#2563EB"
        android:elevation="8dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
