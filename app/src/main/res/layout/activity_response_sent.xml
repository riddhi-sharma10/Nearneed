<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    android:orientation="vertical"
    android:padding="24dp"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close_grey" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Response Confirmation"
            android:textColor="@color/text_header"
            android:textSize="16sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Center Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="48dp">

        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/bg_circle_yellow"
            android:layout_gravity="center_horizontal">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_star_yellow"
                android:importantForAccessibility="no" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Response submitted."
            android:textColor="@color/text_header"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="The organizer has received your profile and will contact you if selected."
            android:textColor="@color/text_subheadline"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card_spot_pink" 
            android:text="Waiting for organizer to respond."
            android:textColor="@color/brand_error_solid"
            android:textSize="13sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp" />

        <!-- Auto redirect block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvAutoRedirect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="auto-redirect in 3s"
                android:textColor="@color/brand_error_solid"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <ProgressBar
                android:id="@+id/pbAutoRedirect"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginStart="32dp"
                android:layout_marginEnd="32dp"
                android:progress="100"
                android:max="100"
                android:progressDrawable="@drawable/bg_progress_bar_red_flat" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackToFeed"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="40dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:text="Back to Feed"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="@color/brand_error_solid"
            app:cornerRadius="16dp"
            android:elevation="0dp" />
    </LinearLayout>
</LinearLayout>









