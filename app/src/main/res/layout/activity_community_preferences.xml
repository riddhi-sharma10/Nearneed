<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:layout_centerVertical="true" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_back_arrow" />
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Profile Setup"
                    android:textColor="@color/text_header"
                    android:textSize="16sp" />
            </RelativeLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:orientation="horizontal" android:weightSum="1" android:gravity="center_vertical">
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Community Preferences"
                    android:textColor="@color/text_header"
                    android:textSize="14sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Step 4/4" android:textColor="@color/text_muted" android:textSize="12sp" />
            </LinearLayout>
            <ProgressBar style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="8dp" android:progress="100" android:max="100" android:progressDrawable="@drawable/bg_progress_bar_red_flat" />

            <TextView
                style="@style/AppHero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Emergency Notifications"
                android:textColor="@color/text_header"
                android:textSize="24sp"
                android:letterSpacing="-0.02" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_district_pill_input_white_stroke"
                android:elevation="6dp"
                android:outlineAmbientShadowColor="@color/shadow_ambient"
                android:outlineSpotShadowColor="@color/shadow_spot">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_solid_bell" app:tint="@color/brand_error_solid" android:layout_gravity="center" />
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="12dp">
                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Help Notifications"
                        android:textColor="@color/text_header"
                        android:textSize="14sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Push notification when someone needs help" android:textColor="@color/text_subheadline" android:textSize="12sp" />
                </LinearLayout>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleX="0.75"
                    android:scaleY="0.75"
                    app:thumbTint="@color/sel_switch_thumb_red"
                    app:trackTint="@color/sel_switch_track_red"
                    app:useMaterialThemeColors="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_district_pill_input_white_stroke"
                android:elevation="6dp"
                android:outlineAmbientShadowColor="@color/shadow_ambient"
                android:outlineSpotShadowColor="@color/shadow_spot">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_solid_sms" app:tint="@color/brand_error_solid" android:layout_gravity="center" />
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="12dp">
                    <TextView style="@style/AppHeading" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Notify me via SMS" android:textColor="@color/text_header" android:textSize="14sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SMS notification to +91 99XXXXX99" android:textColor="@color/text_subheadline" android:textSize="12sp" />
                </LinearLayout>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleX="0.75"
                    android:scaleY="0.75"
                    app:thumbTint="@color/sel_switch_thumb_red"
                    app:trackTint="@color/sel_switch_track_red"
                    app:useMaterialThemeColors="false" />
            </LinearLayout>

            <TextView
                style="@style/AppHero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="Notification Radius"
                android:textColor="@color/text_header"
                android:textSize="24sp"
                android:letterSpacing="-0.02" />

            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:singleSelection="true">
                <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="48dp" android:text="3km" style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_red" app:chipStrokeColor="@color/sel_chip_stroke_red" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_red" android:checked="true"/>
                <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="48dp" android:text="5km" style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_red" app:chipStrokeColor="@color/sel_chip_stroke_red" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_red" />
                <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="48dp" android:text="7km" style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_red" app:chipStrokeColor="@color/sel_chip_stroke_red" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_red" />
                <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="48dp" android:text="10km" style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_red" app:chipStrokeColor="@color/sel_chip_stroke_red" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_red" />
            </com.google.android.material.chip.ChipGroup>

            <TextView
                style="@style/AppHero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="Skills/resources you can offer?"
                android:textColor="@color/text_header"
                android:textSize="24sp"
                android:letterSpacing="-0.02" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Letting neighbors know how you can help in an emergency." android:textColor="@color/text_subheadline" android:textSize="13sp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cgSkills"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.chip.Chip android:id="@+id/chipCar" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Car" style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_red" app:chipStrokeColor="@color/sel_chip_stroke_red" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_red" />
                <com.google.android.material.chip.Chip android:id="@+id/chipMedical" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Medical" style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_red" app:chipStrokeColor="@color/sel_chip_stroke_red" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_red" />
                <com.google.android.material.chip.Chip android:id="@+id/chipFirstAid" android:layout_width="wrap_content" android:layout_height="48dp" android:text="First Aid" style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_red" app:chipStrokeColor="@color/sel_chip_stroke_red" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_red" />
                <com.google.android.material.chip.Chip android:id="@+id/chipWater" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Water" style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_red" app:chipStrokeColor="@color/sel_chip_stroke_red" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_red"/>
                <com.google.android.material.chip.Chip android:id="@+id/chipFoodKit" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Food/Kit" style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_red" app:chipStrokeColor="@color/sel_chip_stroke_red" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_red"/>
                <com.google.android.material.chip.Chip android:id="@+id/chipSupplies" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Supplies" style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_red" app:chipStrokeColor="@color/sel_chip_stroke_red" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_red" />
                <com.google.android.material.chip.Chip android:id="@+id/chipShelter" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Shelter" style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_red" app:chipStrokeColor="@color/sel_chip_stroke_red" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_red" />
                <com.google.android.material.chip.Chip android:id="@+id/chipTransport" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Transport" style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_red" app:chipStrokeColor="@color/sel_chip_stroke_red" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_red" />
                <com.google.android.material.chip.Chip android:id="@+id/chipTools" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Tools" style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_red" app:chipStrokeColor="@color/sel_chip_stroke_red" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_red"/>
                <com.google.android.material.chip.Chip android:id="@+id/chipOther" android:layout_width="wrap_content" android:layout_height="48dp" android:text="+ Other" style="@style/Widget.MaterialComponents.Chip.Choice" app:chipBackgroundColor="@color/sel_chip_bg_red" app:chipStrokeColor="@color/sel_chip_stroke_red" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_red"/>
            </com.google.android.material.chip.ChipGroup>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilOtherSkill"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/brand_error_solid"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:hintEnabled="false"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etOtherSkill"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="What else can you offer?"
                    android:inputType="text"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="32dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnter"
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="24dp"
                android:text="Enter"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="@color/brand_error_solid"
                app:strokeColor="#F1F5F9"
                app:strokeWidth="1dp"
                app:cornerRadius="16dp"
                android:elevation="0dp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>








