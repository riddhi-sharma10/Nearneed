<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="24dp">
                <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:layout_centerVertical="true" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_back_arrow" />
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Profile Setup"
                    android:textColor="@color/text_header"
                    android:textSize="16sp" />
            </RelativeLayout>

            <!-- Progress Bar -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:orientation="horizontal" android:weightSum="1" android:gravity="center_vertical" android:paddingHorizontal="24dp">
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Gig Mode Setup"
                    android:textColor="@color/text_header"
                    android:textSize="14sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Step 2/4" android:textColor="@color/text_muted" android:textSize="12sp" />
            </LinearLayout>
            <ProgressBar style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="8dp" android:layout_marginHorizontal="24dp" android:progress="50" android:max="100" android:progressDrawable="@drawable/bg_progress_bar_blue_flat" />

            <TextView
                style="@style/AppHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="24dp"
                android:text="Where are you?"
                android:textColor="@color/text_header"
                android:textSize="32sp"
                android:letterSpacing="-0.03" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:layout_marginHorizontal="24dp" android:text="We use your location to show local gigs and needs around you." android:textColor="@color/text_subheadline" android:textSize="16sp" />

            <!-- MAP CARD District Style -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/white"
                app:cardUseCompatPadding="true"
                android:outlineAmbientShadowColor="@color/shadow_spot"
                android:outlineSpotShadowColor="@color/shadow_spot">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <LinearLayout
                        android:id="@+id/searchContainer"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_district_pill_input_white_stroke"
                        android:elevation="0dp"
                        android:gravity="center_vertical"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_search_grey" app:tint="@color/text_muted" />
                        <EditText
                            android:id="@+id/etSearchLocation"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="12dp"
                            android:background="@android:color/transparent"
                            android:hint="Or search manually"
                            android:textColor="@color/text_header"
                            android:textColorHint="@color/text_muted"
                            android:textSize="14sp"
                            android:imeOptions="actionSearch"
                            android:inputType="textPostalAddress"
                            android:maxLines="1" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView
                                style="@style/AppHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DETECTED LOCATION"
                                android:textColor="@color/text_muted"
                                android:textSize="10sp"
                                android:letterSpacing="0.05" />
                            <TextView
                                style="@style/AppHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BML Munjal University, Kaphera"
                                android:textColor="@color/text_header"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="12dp"
                        android:background="@color/border_standard">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_loc_pin_small" app:tint="@color/brand_primary" android:layout_gravity="center" />
                    </FrameLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUseLocation"
                        style="@style/AppHeading"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:text="Use this location"
                        android:textColor="@color/white"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        app:backgroundTint="@color/brand_primary"
                        app:cornerRadius="16dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <TextView
                style="@style/AppHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginHorizontal="24dp"
                android:text="GIG/NEED POST SCROLLING RADIUS"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:letterSpacing="0.05" />

            <!-- Radius Options Styled Rows -->
            <LinearLayout
                android:id="@+id/opt5km"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="24dp"
                android:background="@drawable/bg_radius_option_unselected"
                android:padding="16dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv5kmTitle"
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 Kilometers"
                    android:textColor="@color/text_header"
                    android:textSize="16sp"/>
                <TextView android:id="@+id/tv5kmDesc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Matches from very close neighbors." android:textColor="@color/text_muted" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/opt7km"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="24dp"
                android:background="@drawable/bg_radius_option_unselected"
                android:padding="16dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv7kmTitle"
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7 Kilometers"
                    android:textColor="@color/text_header"
                    android:textSize="16sp"/>
                <TextView android:id="@+id/tv7kmDesc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ideal for local neighborhood connections." android:textColor="@color/text_muted" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/opt10km"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="24dp"
                android:background="@drawable/bg_radius_option_unselected"
                android:padding="16dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv10kmTitle"
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10 Kilometers"
                    android:textColor="@color/text_header"
                    android:textSize="16sp"/>
                <TextView android:id="@+id/tv10kmDesc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wider reach across your locality." android:textColor="@color/text_muted" android:textSize="12sp"/>
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="32dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinue"
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginHorizontal="24dp"
                android:text="Continue"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="16dp"
                android:elevation="0dp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>








