<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:layout_centerVertical="true" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_back_arrow" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" android:text="Profile Setup" android:textColor="#101D33" android:textSize="16sp" android:textStyle="bold" />
            </RelativeLayout>

            <!-- Progress Bar -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:orientation="horizontal" android:weightSum="1" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Gig Mode Setup" android:textColor="#101D33" android:textSize="14sp" android:fontFamily="sans-serif-medium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Step 2/4" android:textColor="#94A3B8" android:textSize="12sp" />
            </LinearLayout>
            <ProgressBar style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="8dp" android:progress="50" android:max="100" android:progressDrawable="@drawable/bg_progress_bar_blue_flat" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:text="Where are you?" android:textColor="#101D33" android:textSize="32sp" android:fontFamily="sans-serif-black" android:letterSpacing="-0.03" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="We use your location to show local gigs and needs around you." android:textColor="#64748B" android:textSize="16sp" />

            <!-- MAP CARD District Style -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardUseCompatPadding="true"
                android:outlineAmbientShadowColor="#1A000000"
                android:outlineSpotShadowColor="#1A000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_verified_badge" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DETECTED LOCATION" android:textColor="#94A3B8" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.05" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BML Munjal University, Kaphera" android:textColor="#101D33" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="16dp"
                        android:background="#E2E8F0">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_loc_pin_small" app:tint="#1D5EF3" android:layout_gravity="center" />
                    </FrameLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUseLocation"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:text="Use this location"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        app:backgroundTint="#1D5EF3"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Search manually bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_district_pill_input_white_stroke"
                android:elevation="6dp"
                android:outlineAmbientShadowColor="#0F000000"
                android:outlineSpotShadowColor="#1A000000"
                android:gravity="center_vertical"
                android:paddingStart="24dp">
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_search_grey" app:tint="#94A3B8" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="Or search manually" android:textColor="#94A3B8" android:textSize="14sp" />
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:text="GIG/NEED POST SCROLLING RADIUS" android:textColor="#94A3B8" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.05" />

            <!-- Radius Options Styled Rows -->
            <LinearLayout
                android:id="@+id/opt5km"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_radius_option_unselected"
                android:padding="16dp"
                android:orientation="vertical">
                <TextView android:id="@+id/tv5kmTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5 Kilometers" android:textColor="#0F172A" android:textStyle="bold" android:textSize="16sp"/>
                <TextView android:id="@+id/tv5kmDesc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Matches from very close neighbors." android:textColor="#94A3B8" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/opt7km"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_radius_option_unselected"
                android:padding="16dp"
                android:orientation="vertical">
                <TextView android:id="@+id/tv7kmTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="7 Kilometers" android:textColor="#0F172A" android:textStyle="bold" android:textSize="16sp"/>
                <TextView android:id="@+id/tv7kmDesc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ideal for local neighborhood connections." android:textColor="#94A3B8" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/opt10km"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_radius_option_unselected"
                android:padding="16dp"
                android:orientation="vertical">
                <TextView android:id="@+id/tv10kmTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10 Kilometers" android:textColor="#0F172A" android:textStyle="bold" android:textSize="16sp"/>
                <TextView android:id="@+id/tv10kmDesc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wider reach across your locality." android:textColor="#94A3B8" android:textSize="12sp"/>
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="32dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinue"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Continue"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                app:backgroundTint="#1D5EF3"
                app:cornerRadius="16dp"
                android:elevation="0dp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>