<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ── HEADER ── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back_arrow" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="New Gig Post"
                    android:textColor="#101D33"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- ── PROGRESS BAR ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal"
                android:weightSum="1"
                android:gravity="center_vertical"
                android:baselineAligned="false">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Gig details"
                    android:textColor="#101D33"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 1 of 2"
                    android:textColor="#94A3B8"
                    android:textSize="12sp" />
            </LinearLayout>
            <ProgressBar
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="8dp"
                android:progress="50"
                android:max="100"
                android:progressDrawable="@drawable/bg_progress_bar_blue_flat" />

            <!-- ── EDITORIAL HEADLINE ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="What do you need?"
                android:textColor="#101D33"
                android:textSize="32sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.03" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Tell us the task and we'll match you with nearby people."
                android:textColor="#64748B"
                android:textSize="16sp" />

            <!-- ── TASK TITLE ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Task title"
                android:textColor="#0F172A"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etWhatDoYouNeed"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_district_pill_input_white_stroke"
                android:elevation="6dp"
                android:outlineAmbientShadowColor="#0F000000"
                android:outlineSpotShadowColor="#1A000000"
                android:hint="e.g. Help moving furniture"
                android:textColorHint="#94A3B8"
                android:textColor="#101D33"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:inputType="text"
                android:autofillHints="none" />

            <!-- ── DESCRIPTION ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Describe the task"
                android:textColor="#0F172A"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etDescribeTask"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_district_pill_input_white_stroke"
                android:elevation="6dp"
                android:outlineAmbientShadowColor="#0F000000"
                android:outlineSpotShadowColor="#1A000000"
                android:hint="Provide more details — tools needed, urgency, etc."
                android:textColorHint="#94A3B8"
                android:textColor="#101D33"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:padding="20dp"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:autofillHints="none" />

            <!-- ── BUDGET ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Budget (₹)"
                android:textColor="#0F172A"
                android:textSize="14sp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_district_pill_input_white_stroke"
                android:elevation="6dp"
                android:outlineAmbientShadowColor="#0F000000"
                android:outlineSpotShadowColor="#1A000000">

                <EditText
                    android:id="@+id/etPrice"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Set your budget"
                    android:textColorHint="#94A3B8"
                    android:textColor="#101D33"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="20dp"
                    android:paddingEnd="52dp"
                    android:inputType="numberDecimal"
                    android:gravity="center_vertical"
                    android:background="@android:color/transparent"
                    android:autofillHints="none" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="18dp"
                    android:src="@drawable/ic_loc_pin_small"
                    app:tint="#CBD5E1"
                    android:importantForAccessibility="no" />
            </RelativeLayout>

            <!-- Allow Negotiation toggle card -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_district_pill_input_white_stroke"
                android:elevation="6dp"
                android:outlineAmbientShadowColor="#0F000000"
                android:outlineSpotShadowColor="#1A000000"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:id="@+id/llNegotiationText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:baselineAligned="false">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Allow Negotiation"
                        android:textColor="#101D33"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Price can be higher/lower"
                        android:textColor="#94A3B8"
                        android:textSize="13sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchNegotiation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:checked="true"
                    app:trackTint="@color/sel_switch_track_blue"
                    app:thumbTint="@color/sel_switch_thumb_blue" />
            </RelativeLayout>

            <!-- Max counter offer -->
            <RelativeLayout
                android:id="@+id/cardMaxCounter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_district_pill_input_white_stroke"
                android:elevation="6dp"
                android:outlineAmbientShadowColor="#0F000000"
                android:outlineSpotShadowColor="#1A000000"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:alpha="0.4">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="Max counter offer"
                    android:textColor="#64748B"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:baselineAligned="false">

                    <TextView
                        android:id="@+id/btnCounterMinus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="−"
                        android:textColor="#64748B"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:background="@drawable/bg_card_outline"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tvCounterValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="500"
                        android:textColor="#101D33"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:id="@+id/btnCounterPlus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="+"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:background="@drawable/bg_counter_btn"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Inspired by iHire: Suggest a fair price and negotiate with local pros in real-time."
                android:textColor="#64748B"
                android:textSize="13sp"
                app:drawableStartCompat="@drawable/ic_loc_pin_small"
                app:drawableTint="#1D5EF3"
                android:drawablePadding="8dp"
                android:gravity="center_vertical" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="DURATION"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDuration1Hr"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="&lt; 1hr"
                    android:checked="true"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_blue"
                    app:chipStrokeColor="@color/sel_chip_stroke_blue"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_blue" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDuration13Hr"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="1–3hrs"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_blue"
                    app:chipStrokeColor="@color/sel_chip_stroke_blue"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_blue" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDurationHalfDay"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Half Day"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_blue"
                    app:chipStrokeColor="@color/sel_chip_stroke_blue"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_blue" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDurationFullDay"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Full Day"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_blue"
                    app:chipStrokeColor="@color/sel_chip_stroke_blue"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_blue" />
            </com.google.android.material.chip.ChipGroup>

            <!-- ── CATEGORY ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="CATEGORY"
                android:textColor="#94A3B8"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCatCleaning"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Cleaning"
                    android:checked="true"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_blue"
                    app:chipStrokeColor="@color/sel_chip_stroke_blue"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_blue" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCatDelivery"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Delivery"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_blue"
                    app:chipStrokeColor="@color/sel_chip_stroke_blue"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_blue" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCatRepairs"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Repairs"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_blue"
                    app:chipStrokeColor="@color/sel_chip_stroke_blue"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_blue" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCatGardening"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Gardening"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_blue"
                    app:chipStrokeColor="@color/sel_chip_stroke_blue"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_blue" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCatMoving"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Moving"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_blue"
                    app:chipStrokeColor="@color/sel_chip_stroke_blue"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_blue" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCatElectrical"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Electrical"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/sel_chip_bg_blue"
                    app:chipStrokeColor="@color/sel_chip_stroke_blue"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/sel_chip_text_blue" />
            </com.google.android.material.chip.ChipGroup>

            <!-- ── HOW MANY PEOPLE ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="HOW MANY PEOPLE?"
                android:textColor="#94A3B8"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_district_pill_input_white_stroke"
                android:elevation="6dp"
                android:outlineAmbientShadowColor="#0F000000"
                android:outlineSpotShadowColor="#1A000000"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="Number of people needed"
                    android:textColor="#64748B"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/btnPeopleMinus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="−"
                        android:textColor="#64748B"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:background="@drawable/bg_card_outline"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tvPeopleCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textColor="#101D33"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:id="@+id/btnPeoplePlus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="+"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:background="@drawable/bg_counter_btn"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </RelativeLayout>

            <!-- ── PAYMENT METHOD ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="PAYMENT METHOD"
                android:textColor="#94A3B8"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:id="@+id/payUPI"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_payment_selected"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_upi_logo"
                        android:importantForAccessibility="no" />

                    <TextView
                        android:id="@+id/tvPayUPI"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UPI"
                        android:textColor="#1D5EF3"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/payCash"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_payment_unselected"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_cash_icon"
                        android:importantForAccessibility="no" />

                    <TextView
                        android:id="@+id/tvPayCash"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cash"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/payBoth"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_payment_unselected"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_both_payment"
                        android:importantForAccessibility="no" />

                    <TextView
                        android:id="@+id/tvPayBoth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Both"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── WARNING ALERT ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_warning_alert"
                android:padding="14dp"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="⚠"
                    android:textSize="14sp"
                    android:textColor="#D97706"
                    android:gravity="center"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Your post will be marked Unverified until you complete your KYC or link a verified UPI ID in the next step."
                    android:textColor="#92400E"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.3" />
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="40dp" />

            <!-- ── DISTRICT STYLE CTA ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinueGig"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Continue"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                app:backgroundTint="#1D5EF3"
                app:cornerRadius="16dp"
                android:elevation="0dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
